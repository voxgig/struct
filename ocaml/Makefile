# Makefile for the OCaml port of voxgig/struct.
# Requires the OCaml compiler (ocamlc / ocamlopt). No third-party libraries.

OCAMLC = ocamlc
SRC = src/vregex.ml src/voxgig_struct.ml
TESTSRC = $(SRC) test/runner.ml

.PHONY: test lint build inspect clean reset publish

# Build and run the shared JSON corpus through the OCaml implementation.
test: run_tests
	./run_tests

run_tests: $(TESTSRC)
	$(OCAMLC) -I src $(TESTSRC) -o run_tests

# "Lint": type-check the library (a clean compile means it is sound). No
# third-party linter is required; ocamlformat can be wired into this target.
lint:
	$(OCAMLC) -I src -c $(SRC)
	@echo ok

# Build the dune library (also (re)generates voxgig-struct.opam from dune-project).
build:
	dune build

inspect:
	@$(OCAMLC) -version

clean:
	rm -f src/*.cmi src/*.cmo test/*.cmi test/*.cmo run_tests
	rm -rf _build

reset: clean

# Release: build the dune package and submit it to ocaml/opam-repository via a
# PR (opam publish). opam is NOT an instant registry — the PR is reviewed and
# merged by opam maintainers. opam checksums the GitHub source archive, so the
# tag must exist BEFORE opam publish; hence (unlike the other ports) the tag is
# pushed FIRST. A failed opam publish therefore leaves the tag in place — just
# re-run `opam publish` manually. voxgig-struct.opam is generated by dune.
# Auth:
#   GITHUB_TOKEN  pushes the tag; opam publish also needs a GitHub token (repo
#                 scope) to fork opam-repository + open the PR — seed it once
#                 with an interactive `opam publish`, or write the token to
#                 ~/.opam/plugins/opam-publish/<github-user>.token
# Prereq: opam initialised + the opam-publish plugin (opam install opam-publish);
#   the dune-project version must match VERSION (guarded below).
VERSION := $(shell cat VERSION)
TAG := ocaml/v$(VERSION)
ARCHIVE := https://github.com/voxgig/struct/archive/refs/tags/$(TAG).tar.gz
AQL_DRY_RUN_FILLER := AQL-DRY-RUN-FILLER-NOT-A-REAL-SECRET
publish: test
	@if git rev-parse -q --verify "refs/tags/$(TAG)" >/dev/null; then \
	  echo "tag $(TAG) already exists — bump ocaml/VERSION first"; exit 1; fi
	@dpv=$$(grep -oE '[0-9]+\.[0-9]+\.[0-9]+' dune-project | head -1); \
	  [ "$$dpv" = "$(VERSION)" ] || { echo "version mismatch: VERSION=$(VERSION) vs dune-project=$$dpv — bump both"; exit 1; }
	@set -e; \
	token="$${GITHUB_TOKEN:-$$GH_TOKEN}"; \
	if [ "$$token" = "$(AQL_DRY_RUN_FILLER)" ]; then \
	  echo "[dry-run] aql filler token detected: would tag $(TAG) and open an opam-repository PR; nothing pushed."; \
	  exit 0; \
	fi; \
	dune build; \
	git tag -a "$(TAG)" -m "ocaml v$(VERSION)"; \
	if [ -n "$$token" ]; then \
	  hdr="AUTHORIZATION: basic $$(printf 'x-access-token:%s' "$$token" | base64 | tr -d '\n')"; \
	  git -c http.extraheader="$$hdr" push https://github.com/voxgig/struct.git "$(TAG)"; \
	else \
	  git push origin "$(TAG)"; \
	fi; \
	opam publish --no-browser "$(ARCHIVE)"; \
	echo "Tagged $(TAG) and opened an opam-repository PR (review pending)."
