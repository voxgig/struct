  if ((fw is None) or (vg-is-noarg fw)) [false] [true]
]]
def vgi-cb4 fn [[fw:Any a:Any b:Any c:Any d:Any] [Any] [
  def f (vgi-fnarg fw)
  def r (vgi-call4 a b c d (f/r))
  r
]]
def vgl-walk-children fn [[ci:Integer ckeys:Any out:Any fwb:Any fwa:Any md:Integer pth:Any] [Any] [
  if (ci gte (size ckeys)) [none] [
    def ckey (ckeys get ci)
    def cpth (vg-clone pth)
    (append [ckey] cpth) drop
    def cval (vgi-raw out ckey)
    def walked (vgi-walk-rec cval fwb fwa md ckey out cpth)
    (vg-setprop out ckey walked) drop
    def ci1 (ci add 1)
    def r (vgl-walk-children ci1 ckeys out fwb fwa md pth)
    r
  ]
]]
def vgi-walk-rec fn [[val:Any fwb:Any fwa:Any md:Integer key:Any parent:Any pth:Any] [Any] [
  def dep (size pth)
  def out0 (
    if (vgi-has-cb fwb) [vgi-cb4 fwb key val parent pth] [val]
  )
  def stop (
    if (md eq 0) [true] [
      if ((md gt 0) and (md lte dep)) [true] [false]
    ]
  )
  if (stop eq true) [out0] [
    def obox (flex [none])
    (obox set 0 out0) drop
    if (vg-isnode out0) [
      def ckeys (vg-keysof out0)
      (vgl-walk-children 0 ckeys out0 fwb fwa md pth) drop
      none
    ] [none] drop
    def out1 (obox get 0)
    def out2 (
      if (vgi-has-cb fwa) [vgi-cb4 fwa key out1 parent pth] [out1]
    )
    out2
  ]
]]
def vg-walk fn [[val:Any fwb:Any fwa:Any maxdepth:Any] [Any] [
  def md (
    if (maxdepth is Number) [
      if ((vgz maxdepth) gte 0) [vgz maxdepth] [32]
    ] [32]
  )
  def pth0 (flex [])
  def r (vgi-walk-rec val fwb fwa md none none pth0)
