  def dst (st get "dst")
  def md (st get "md")
  def pi (vgz pth)
  if (md lte pi) [
    def tgt (vg-getprop cur (pi sub 1) vg-noarg)
    (vg-setprop tgt key val) drop
    val
  ] [
    if ((vg-isnode val) not) [
      (vg-setprop cur pi val) drop
      val
    ] [
      def dprev (if (pi gt 0) [vg-getprop dst (pi sub 1) vg-noarg] [vg-getprop dst pi vg-noarg])
      def tval (if (pi gt 0) [vg-getprop dprev key vg-noarg] [vg-getprop dst pi vg-noarg])
      (vg-setprop dst pi tval) drop
      def vtype (vg-typify val)
      if ((tval is None) and ((vg-bit vg-t-instance vtype) not)) [
        def fresh (if (vg-islist val) [flex []] [flex {}])
        (vg-setprop cur pi fresh) drop
        val
