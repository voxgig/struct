def vgl-merge-list fn [[oi:Integer lst:Any md:Integer obox:Any] [Any] [
  if (oi gte (size lst)) [none] [
    def obj (lst get oi)
    if ((vg-isnode obj) not) [
      (obox set 0 obj) drop
      none
    ] [
      def st (flex {})
      def cur (flex [])
      def out0 (obox get 0)
      (append [out0] cur) drop
      def dst (flex [])
      (append [out0] dst) drop
      (st set "cur" cur) drop
      (st set "dst" dst) drop
      (st set "md" md) drop
      (append [st] vgi-merge-stack) drop
      def walked (vg-walk obj [vg-merge-before/r] [vg-merge-after/r] md)
