]]


# ----------------------------------------------------------------------------
# Injection state — the recursive engine behind inject / transform /
# validate / select. An Injection is a flex map with the canonical
# fields (mode full keyi keys key val parent path nodes handler errs
# meta dparent dpath base modify prior root). Command functions and
# handlers are fn boxes (see vgi-fnarg).
# ----------------------------------------------------------------------------
def vgi-inj-new fn [[val:Any parent:Any] [Any] [
  def inj (flex {})
  (inj set "mode" 4) drop
  (inj set "full" false) drop
  (inj set "keyi" 0) drop
  def ik (flex [])
  (append ["$TOP"] ik) drop
  (inj set "keys" ik) drop
  (inj set "key" "$TOP") drop
  (inj set "val" val) drop
  (inj set "parent" parent) drop
  def ip (flex [])
  (append ["$TOP"] ip) drop
  (inj set "path" ip) drop
  def inn (flex [])
  (append [parent] inn) drop
  (inj set "nodes" inn) drop
  (inj set "handler" vg-injecthandler-box) drop
  (inj set "errs" (flex [])) drop
  (inj set "meta" (flex {})) drop
  (inj set "dparent" none) drop
  def dp (flex [])
  (append ["$TOP"] dp) drop
  (inj set "dpath" dp) drop
  (inj set "base" "$TOP") drop
  (inj set "modify" none) drop
  (inj set "prior" none) drop
  (inj set "root" none) drop
  inj
]]

def vgi-inj-descend fn [[inj:Any] [Any] [
  def meta (inj get "meta")
  if (vg-ismap meta) [
    def d0 (vg-getprop meta "__d" 0)
    def d (if (d0 is Number) [d0] [0])
    (vg-setprop meta "__d" (d add 1)) drop
    none
  ] [none] drop
  def pth (inj get "path")
  def parentkey (vg-getelem pth -2 vg-noarg)
  def dparent (inj get "dparent")
  def dpath (inj get "dpath")
  if (dparent is None) [
    if ((vgz dpath) gt 1) [
      def ndp (vg-clone dpath)
      (append [parentkey] ndp) drop
      (inj set "dpath" ndp) drop
      none
    ] [none] drop
    none
  ] [
    if ((parentkey is None) not) [
      def ndparent (vg-getprop dparent parentkey vg-noarg)
      (inj set "dparent" ndparent) drop
      def lastpart (vg-getelem dpath -1 vg-noarg)
      def pk (vg-js-string parentkey)
      def marker (StringUtil.concat ["$:" pk])
      if (lastpart eq marker) [
        def ndp (vg-slice dpath -1 vg-noarg vg-noarg)
        (inj set "dpath" ndp) drop
        none
      ] [
        def ndp (vg-clone dpath)
        (append [parentkey] ndp) drop
        (inj set "dpath" ndp) drop
        none
      ] drop
      none
    ] [none] drop
    none
  ] drop
  inj get "dparent"
]]

def vgi-inj-child fn [[inj:Any keyi:Integer ikeys:Any] [Any] [
  def key (vg-strkey (vg-getelem ikeys keyi vg-noarg))
  def val (inj get "val")
  def c (flex {})
  (c set "mode" (inj get "mode")) drop
  (c set "full" (inj get "full")) drop
  (c set "keyi" keyi) drop
  (c set "keys" ikeys) drop
  (c set "key" key) drop
  (c set "val" (vg-getprop val key vg-noarg)) drop
  (c set "parent" val) drop
  def npth (vg-clone (inj get "path"))
  (append [key] npth) drop
  (c set "path" npth) drop
  def nnodes (vg-clone-shallow (inj get "nodes"))
  (append [val] nnodes) drop
  (c set "nodes" nnodes) drop
  (c set "handler" (inj get "handler")) drop
  (c set "errs" (inj get "errs")) drop
  (c set "meta" (inj get "meta")) drop
  (c set "base" (inj get "base")) drop
  (c set "modify" (inj get "modify")) drop
  (c set "prior" inj) drop
  (c set "dpath" (vg-clone (inj get "dpath"))) drop
  (c set "dparent" (inj get "dparent")) drop
  (c set "root" (inj get "root")) drop
