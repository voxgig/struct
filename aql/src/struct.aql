        if (v is String) [vgi-esc-json v] [
          if (vg-islist v) [
            if ((size v) eq 0) ["[]"] [
              def parts0 (flex [])
              def parts (vgl-jenc-list 0 v parts0)
              def body (vgi-join-list parts ",")
