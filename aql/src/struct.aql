# ----------------------------------------------------------------------------
# getpath / setpath — path reads and writes with the injection extensions
# ($KEY, $GET:, $REF:, $META:, $$ escapes, empty-part ascents).
# The optional injdef is a map (or an Injection state map).
# ----------------------------------------------------------------------------
def vgi-idef fn [[injdef:Any k:String] [Any] [
  if (injdef is Map) [injdef get (k)] [none]
]]

def vgl-getpath-parts fn [[pi:Integer parts:Any vbox:Any store:Any src:Any injdef:Any dparent:Any dpath:Any contbox:Any] [Any] [
  def numparts (size parts)
  def going (
    if ((contbox get 0) eq true) [
      if (((vbox get 0) is None) not) [pi lt numparts] [false]
    ] [false]
  )
  if (going eq false) [none] [
    def raw (parts get pi)
    def hasinj (injdef is Map)
    def part0 (
      if ((hasinj eq true) and (raw eq "$KEY")) [
        def kv (vgi-idef injdef "key")
        if (kv is None) [raw] [kv]
      ] [
        if (raw is String) [
          if ((hasinj eq true) and (vgi-starts-with raw "$GET:")) [
            def gp (vg-slice raw 5 -1 vg-noarg)
            def gv (vg-getpath src gp vg-noarg)
            def btr19 (if (gv is None) [""] [vg-stringify gv vg-noarg vg-noarg])
            btr19
          ] [
            if ((hasinj eq true) and (vgi-starts-with raw "$REF:")) [
              def rp (vg-slice raw 5 -1 vg-noarg)
              def spec (vg-getprop store "$SPEC" vg-noarg)
              def rv (vg-getpath spec rp vg-noarg)
              def btr20 (if (rv is None) [""] [vg-stringify rv vg-noarg vg-noarg])
              btr20
            ] [
              if ((hasinj eq true) and (vgi-starts-with raw "$META:")) [
                def mp (vg-slice raw 6 -1 vg-noarg)
                def mv0 (vgi-idef injdef "meta")
                def mv (vg-getpath mv0 mp vg-noarg)
                def btr21 (if (mv is None) [""] [vg-stringify mv vg-noarg vg-noarg])
                btr21
              ] [raw]
            ]
          ]
        ] [raw]
      ]
    )
    def part (
      if (part0 is String) [
        if (StringUtil.contains "$$" part0) [
          StringUtil.replace "$$" "$" part0 {scope: "all"}
        ] [part0]
      ] [vg-strkey part0]
    )
    if (part eq "") [
      def abox (flex [0])
      def pbox (flex [pi])
      (vgl-count-ascends parts pbox abox) drop
      def ascends (abox get 0)
      def npi (pbox get 0)
      if ((hasinj eq true) and (ascends gt 0)) [
        def asc2 (if (npi eq (numparts sub 1)) [ascends sub 1] [ascends])
        if (asc2 eq 0) [
          (vbox set 0 dparent) drop
          (pbox set 0 (npi add 1)) drop
          def r (vgl-getpath-parts (pbox get 0) parts vbox store src injdef dparent dpath contbox)
          r
        ] [
          def dslice (vg-slice dpath (0 sub asc2) vg-noarg vg-noarg)
          def tail2 (vg-slice parts (npi add 1) vg-noarg vg-noarg)
          def fp0 (flex [])
          (append [dslice] fp0) drop
          (append [tail2] fp0) drop
          def fullpath (vg-flatten fp0 1)
          if (asc2 lte (vgz dpath)) [
            def fv (vg-getpath store fullpath vg-noarg)
            (vbox set 0 fv) drop
            none
          ] [
            (vbox set 0 none) drop
            none
          ] drop
          (contbox set 0 false) drop
          none
        ]
      ] [
        (vbox set 0 dparent) drop
        def npi1 (npi add 1)
        def r (vgl-getpath-parts npi1 parts vbox store src injdef dparent dpath contbox)
        r
      ]
    ] [
      def cv (vg-getprop (vbox get 0) part vg-noarg)
      (vbox set 0 cv) drop
      def pi1 (pi add 1)
      def r (vgl-getpath-parts pi1 parts vbox store src injdef dparent dpath contbox)
