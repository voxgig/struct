# Shallow list copy: fresh flex list sharing the same element references
# (clone would copy the ancestor nodes themselves, breaking identity).
def vgl-shallow fn [[i:Integer xs:Any acc:Any] [Any] [
  if (i gte (size xs)) [acc] [
    def e (xs get i)
    (append [e] acc) drop
    def i1 (i add 1)
    def r (vgl-shallow i1 xs acc)
    r
  ]
]]
def vg-clone-shallow fn [[xs:Any] [Any] [
  def acc0 (flex [])
  def r (vgl-shallow 0 xs acc0)
  r
]]

def vgi-inj-setval fn [[inj:Any val:Any ancestor:Integer] [Any] [
  def tgt (
    if (ancestor lt 2) [inj get "parent"] [
      def btr22 (vg-getelem (inj get "nodes") (0 sub ancestor) vg-noarg)
      btr22
    ]
  )
  def tkey (
    if (ancestor lt 2) [inj get "key"] [
      def btr23 (vg-getelem (inj get "path") (0 sub ancestor) vg-noarg)
      btr23
    ]
  )
  if (val is None) [
    def r (vg-delprop tgt tkey)
    r
  ] [
    def r (vg-setprop tgt tkey val)
    r
  ]
]]

# ----------------------------------------------------------------------------
# _injectstr — inject store values into a string via `path` markers.
# ----------------------------------------------------------------------------
def vgl-injectstr-parts fn [[i:Integer ms:Any s:String store:Any inj:Any acc:Any posbox:Any] [Any] [
  if (i gte (size ms)) [acc] [
    def m (ms get i)
    def mi (m get "i")
    def me (m get "e")
    (append [(s slice (posbox get 0) mi)] acc) drop
    def gs (m get "g")
    def ref0 (gs get 0)
    def iref (
      if ((size ref0) gt 3) [
        def r1 (StringUtil.replace "$BT" "`" ref0 {scope: "all"})
        StringUtil.replace "$DS" "$" r1 {scope: "all"}
      ] [ref0]
    )
    if (inj is Map) [(inj set "full" false) drop none] [none] drop
    def found (vg-getpath store iref inj)
    def rep (
      if (found is None) [""] [
        if (found is String) [
          if (found eq "__NULL__") ["null"] [found]
        ] [
          if (vg-isfunc found) [""] [vgi-json-encode found]
        ]
      ]
    )
    (append [rep] acc) drop
    (posbox set 0 me) drop
    def i1 (i add 1)
    def r (vgl-injectstr-parts i1 ms s store inj acc posbox)
    r
  ]
]]
def vgi-injectstr fn [[val:Any store:Any inj:Any] [Any] [
  if ((val is String) not) [""] [
    if (val eq "") [""] [
      def fm (vg-re-find "^`(\\$[A-Z]+|[^`]*)[0-9]*`$" val)
      if ((fm is None) not) [
        if (inj is Map) [(inj set "full" true) drop none] [none] drop
        def pathref0 (fm get 1)
        def pathref (
          if ((size pathref0) gt 3) [
            def r1 (StringUtil.replace "$BT" "`" pathref0 {scope: "all"})
            StringUtil.replace "$DS" "$" r1 {scope: "all"}
          ] [pathref0]
        )
        def r (vg-getpath store pathref inj)
        r
      ] [
        def mr ((val) mini re "`([^`]+)`" {all: true})
        def out0 (
          if ((mr get "ok") eq true) [
            def acc (flex [])
            def posbox (flex [0])
            def ms (mr get "ms")
            (vgl-injectstr-parts 0 ms val store inj acc posbox) drop
            def pend (posbox get 0)
            (append [(val slice pend (size val))] acc) drop
            def btr24 (vgi-join-list acc "")
            btr24
          ] [val]
        )
        def handler (if (inj is Map) [inj get "handler"] [none])
        if (vg-isfunc handler) [
          (inj set "full" true) drop
          def hv (vgi-cb4 handler inj out0 val store)
          hv
        ] [out0]
      ]
    ]
  ]
]]

# ----------------------------------------------------------------------------
# inject — the recursive injection engine.
# ----------------------------------------------------------------------------
def vgi-strkeys fn [[i:Integer xs:Any acc:Any] [Any] [
  if (i gte (size xs)) [acc] [
    def e (xs get i)
    (append [(vg-js-string e)] acc) drop
    def i1 (i add 1)
    def r (vgi-strkeys i1 xs acc)
    r
  ]
]]
# Partition sorted keys into non-$ then $ groups (both sorted).
def vgl-part-keys fn [[i:Integer ks:Any nodollar:Any dollar:Any] [Any] [
  if (i gte (size ks)) [none] [
    def k (ks get i)
    if (StringUtil.contains "$" k) [(append [k] dollar) drop none] [(append [k] nodollar) drop none] drop
    def i1 (i add 1)
    def r (vgl-part-keys i1 ks nodollar dollar)
    r
  ]
]]
def vgi-inject-nodekeys fn [[val:Any] [Any] [
  if (vg-ismap val) [
    def ks (sort (keys val))
    def nodollar (flex [])
    def dollar (flex [])
    (vgl-part-keys 0 ks nodollar dollar) drop
    (vgl-shallow 0 dollar nodollar) drop
    nodollar
  ] [
    def acc0 (flex [])
    def r (vgl-idx-keys 0 (size val) acc0)
    r
  ]
]]

def vgl-inject-children fn [[nki:Integer nodekeys:Any val:Any store:Any inj:Any] [Any] [
  if (nki gte (size nodekeys)) [none] [
    def childinj (vgi-inj-child inj nki nodekeys)
    def nodekey (childinj get "key")
    (childinj set "mode" 1) drop
    def prekey (vgi-injectstr (vg-js-string nodekey) store childinj)
    def ks1 (vgi-strkeys 0 (childinj get "keys") (flex []))
    if ((prekey is None) not) [
      (childinj set "val" (vg-getprop val prekey vg-noarg)) drop
      (childinj set "mode" 4) drop
      (vg-inject (childinj get "val") store childinj) drop
      (childinj set "mode" 2) drop
      (vgi-injectstr (vg-js-string nodekey) store childinj) drop
      none
    ] [none] drop
    def ks2 (vgi-strkeys 0 (childinj get "keys") (flex []))
    def nki1 ((childinj get "keyi") add 1)
    def r (vgl-inject-children nki1 ks2 val store inj)
    r
  ]
]]

def vg-inject fn [[val:Any store:Any injdef:Any] [Any] [
  def idf (if (vg-is-noarg injdef) [none] [injdef])
  def isinj (
    if (idf is Map) [((idf get "mode") is None) not] [false]
  )
  def inj (
    if (isinj eq true) [idf] [
      def rootparent (flex {})
      (rootparent set "$TOP" val) drop
      def ninj (vgi-inj-new val rootparent)
      (ninj set "dparent" store) drop
      def errs0 (vg-getprop store "$ERRS" vg-noarg)
      def errs (if (errs0 is None) [flex []] [errs0])
      (ninj set "errs" errs) drop
      def meta (ninj get "meta")
      (vg-setprop meta "__d" 0) drop
      (ninj set "root" rootparent) drop
      if (idf is Map) [
        def imod (idf get "modify")
        if ((imod is None) not) [(ninj set "modify" imod) drop none] [none] drop
        def iextra (idf get "extra")
        if ((iextra is None) not) [(ninj set "extra" iextra) drop none] [none] drop
        def imeta (idf get "meta")
        if ((imeta is None) not) [(ninj set "meta" imeta) drop none] [none] drop
        def ihandler (idf get "handler")
        if ((ihandler is None) not) [(ninj set "handler" ihandler) drop none] [none] drop
        none
      ] [none] drop
      ninj
    ]
  )
  (vgi-inj-descend inj) drop
  def rv (
    if (vg-isnode val) [
      def nodekeys (vgi-inject-nodekeys val)
      (vgl-inject-children 0 nodekeys val store inj) drop
      val
    ] [
      if (val is String) [
        (inj set "mode" 4) drop
        def nv (vgi-injectstr val store inj)
        if (vg-is-skip nv) [none] [
          (vgi-inj-setval inj nv 1) drop
          none
        ] drop
        nv
      ] [val]
    ]
  )
  def imod (inj get "modify")
  def skiprv (vg-is-skip rv)
  if ((vg-isfunc imod) and (skiprv not)) [
    def mkey (inj get "key")
    def mparent (inj get "parent")
    def mval (vg-getprop mparent mkey vg-noarg)
    def mf (vgi-fnarg imod)
    (vgi-call5 mval mkey mparent inj store (mf/r)) drop
    none
  ] [none] drop
  (inj set "val" rv) drop
  def prior (inj get "prior")
  def root (inj get "root")
  if ((prior is None) and ((root is None) not)) [
    if (vg-haskey root "$TOP") [vg-getprop root "$TOP" vg-noarg] [
      def btr25 (vgi-lookup root "$TOP")
      btr25
    ]
  ] [
    def ikey (inj get "key")
    def iparent (inj get "parent")
    if ((ikey eq "$TOP") and (vg-ismap iparent)) [
      def btr26 (vgi-lookup iparent "$TOP")
      btr26
    ] [rv]
  ]
]]


# ----------------------------------------------------------------------------
# Handler utilities: placement checks, argument validation, child injection.
# ----------------------------------------------------------------------------
def vg-checkplacement fn [[modes:Integer ijname:String parenttypes:Integer inj:Any] [Boolean] [
  def imode (inj get "mode")
  def errs (inj get "errs")
  if ((BinUtil.band modes imode) eq 0) [
    def want (flex [])
    if ((BinUtil.band modes 1) gt 0) [(append ["key"] want) drop none] [none] drop
    if ((BinUtil.band modes 2) gt 0) [(append ["key"] want) drop none] [none] drop
    if ((BinUtil.band modes 4) gt 0) [(append ["value"] want) drop none] [none] drop
    def wantstr (vgi-join-list want ",")
    def pl (vg-getprop vg-placement-table imode "value")
    def msg (StringUtil.concat ["$" ijname ": invalid placement as " pl ", expected: " wantstr "."])
    (append [msg] errs) drop
    false
  ] [
    if (parenttypes eq 0) [true] [
      def ptype (vg-typify (inj get "parent"))
      if ((BinUtil.band parenttypes ptype) eq 0) [
        def pn (vg-typename ptype)
        def wn (vg-typename parenttypes)
        def msg (StringUtil.concat ["$" ijname ": invalid placement in parent " pn ", expected: " wn "."])
        (append [msg] errs) drop
        false
      ] [true]
    ]
  ]
]]

def vgl-injectorargs fn [[argi:Integer argtypes:Any iargs:Any found:Any] [Any] [
  if (argi gte (size argtypes)) [found] [
    # An absent slot is canonical `undefined`: type nil, rendered empty.
    def absent (argi gte (vgz iargs))
    def arg (if (absent eq true) [none] [vg-getprop iargs argi vg-noarg])
    def argtype (if (absent eq true) [vg-t-noval] [vg-typify arg])
    def want (argtypes get argi)
    if ((BinUtil.band want argtype) eq 0) [
      def as2 (if (absent eq true) [""] [vg-stringify arg 22 vg-noarg])
      def tn (vg-typename argtype)
      def wn (vg-typename want)
      def pos (vg-num-to-string (argi add 1))
      def msg (StringUtil.concat ["invalid argument: " as2 " (" tn " at position " pos ") is not of type: " wn "."])
      (found set 0 msg) drop
      found
    ] [
      (found set (argi add 1) arg) drop
      def a1 (argi add 1)
      def r (vgl-injectorargs a1 argtypes iargs found)
      r
    ]
  ]
]]
def vgl-pad-nones fn [[i:Integer n:Integer found:Any] [Any] [
  if (i lt n) [
    (append [none] found) drop
    def r (vgl-pad-nones (i add 1) n found)
    r
  ] [found]
]]
def vg-injectorargs fn [[argtypes:Any iargs:Any] [Any] [
  # found has 1+numargs slots, all none; slot 0 carries the error message.
  def found (flex [])
  def n ((size argtypes) add 1)
  (vgl-pad-nones 0 n found) drop
  def r (vgl-injectorargs 0 argtypes iargs found)
  r
]]

def vg-injectchild fn [[child:Any store:Any inj:Any] [Any] [
  def prior (inj get "prior")
  def cinj (
    if (prior is None) [inj] [
      def pprior (prior get "prior")
      if ((pprior is None) not) [
        def c (vgi-inj-child pprior (prior get "keyi") (prior get "keys"))
        (c set "val" child) drop
        (vg-setprop (c get "parent") (prior get "key") child) drop
        c
      ] [
        def c (vgi-inj-child prior (inj get "keyi") (inj get "keys"))
        (c set "val" child) drop
        (vg-setprop (c get "parent") (inj get "key") child) drop
        c
      ]
    ]
  )
  (vg-inject child store cinj) drop
  cinj
]]

# ----------------------------------------------------------------------------
# The transform command handlers ($DELETE, $COPY, $KEY, …). Each takes
# (inj, val, ref, store); they live in the store as fn boxes.
# ----------------------------------------------------------------------------
def vg-t-delete fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  (vgi-inj-setval inj none 1) drop
  none
]]

def vg-t-copy fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (vg-checkplacement 4 "COPY" vg-t-any inj) [
    def tcout (vgi-lookup (inj get "dparent") (inj get "key"))
    (vgi-inj-setval inj tcout 1) drop
    tcout
  ] [none]
]]

def vg-t-key fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (((inj get "mode") eq 4) not) [none] [
    def parent (inj get "parent")
    def keyspec (vgi-lookup parent "`$KEY`")
    if ((keyspec is None) not) [
      (vg-delprop parent "`$KEY`") drop
      def r (vg-getprop (inj get "dparent") keyspec vg-noarg)
      r
    ] [
      def anno (vgi-lookup parent "`$ANNO`")
      def kv (vgi-lookup anno "KEY")
      if ((kv is None) not) [kv] [
        def r (vg-getelem (inj get "path") -2 vg-noarg)
        r
      ]
    ]
  ]
]]

def vg-t-anno fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  (vg-delprop (inj get "parent") "`$ANNO`") drop
  none
]]

def vg-t-merge fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def imode (inj get "mode")
  def ikey (inj get "key")
  def parent (inj get "parent")
  if (imode eq 1) [ikey] [
    if (imode eq 2) [
      def margs0 (vg-getprop parent ikey vg-noarg)
      def margs (
        if (vg-islist margs0) [margs0] [
          def w (flex [])
          (append [margs0] w) drop
          w
        ]
      )
      (vgi-inj-setval inj none 1) drop
      def ml (flex [])
      (append [parent] ml) drop
      (vgl-shallow 0 margs ml) drop
      (append [(vg-clone parent)] ml) drop
      (vg-merge ml vg-noarg) drop
      ikey
    ] [none]
  ]
]]

def vg-t-each fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (vg-checkplacement 4 "EACH" vg-t-list inj) [
    def ikeys (inj get "keys")
    (vg-slice ikeys 0 1 true) drop
    def parent (inj get "parent")
    def cargs (vg-slice parent 1 vg-noarg vg-noarg)
    def want (flex [])
    (append [vg-t-string] want) drop
    (append [vg-t-any] want) drop
    def found (vg-injectorargs want cargs)
    def errv (found get 0)
    if ((errv is None) not) [
      def msg (StringUtil.concat ["$EACH: " errv])
      (append [msg] (inj get "errs")) drop
      none
    ] [
      def srcpath (found get 1)
      def child (found get 2)
      def ibase (inj get "base")
      def srcstore (vg-getprop store ibase store)
      def src (vg-getpath srcstore srcpath inj)
      def srctype (vg-typify src)
      def ipath (inj get "path")
      def inodes (inj get "nodes")
      def tkey (vg-getelem ipath -2 vg-noarg)
      def target0 (vg-getelem inodes -2 vg-noarg)
      def target (if (target0 is None) [vg-getelem inodes -1 vg-noarg] [target0])
      def tval (
        if (vg-bit vg-t-list srctype) [
          def acc (flex [])
          def prs (vg-items src)
          def mkcopy ([pr:Any] => [vg-clone child])
          def ter1 (vgl-items-apply 0 prs [mkcopy/r] acc)
          ter1
        ] [
          if (vg-bit vg-t-map srctype) [
            def acc (flex [])
            def prs (vg-items src)
            def mkcopy2 ([pr:Any] => [
              def c2 (vg-clone child)
              def annok (flex {})
              def kv (flex {})
              (vg-setprop kv "KEY" (pr get 0)) drop
              (vg-setprop annok "`$ANNO`" kv) drop
              def ml (flex [])
              (append [c2] ml) drop
              (append [annok] ml) drop
              def r2 (vg-merge ml 1)
              r2
            ])
            def ter2 (vgl-items-apply 0 prs [mkcopy2/r] acc)
            ter2
          ] [flex []]
        ]
      )
      def rvalbox (flex [none])
      (rvalbox set 0 (flex [])) drop
      if ((vgz tval) gt 0) [
        def tcur0 (
          if (src is None) [none] [
            def acc2 (flex [])
            def prs2 (vg-items src)
            def getv ([pr:Any] => [pr get 1])
            def ter3 (vgl-items-apply 0 prs2 [getv/r] acc2)
            ter3
          ]
        )
        def ckey (vg-getelem ipath -2 vg-noarg)
        def tpath (vg-slice ipath -1 vg-noarg vg-noarg)
        def dpath (flex [])
        (append ["$TOP"] dpath) drop
        def sparts (make FlexList (StringUtil.split "." srcpath {keepEmpty: true}))
        (vgl-shallow 0 sparts dpath) drop
        (append [(StringUtil.concat ["$:" (vg-js-string ckey)])] dpath) drop
        def tcur1 (flex {})
        (vg-setprop tcur1 ckey tcur0) drop
        def tcurbox (flex [none])
        (tcurbox set 0 tcur1) drop
        if ((vgz tpath) gt 1) [
          def pkey (vg-getelem ipath -3 "$TOP")
          def tcur2 (flex {})
          (vg-setprop tcur2 pkey (tcurbox get 0)) drop
          (tcurbox set 0 tcur2) drop
          (append [(StringUtil.concat ["$:" (vg-js-string pkey)])] dpath) drop
          none
        ] [none] drop
        def ck1 (flex [])
        (append [ckey] ck1) drop
        def tinj (vgi-inj-child inj 0 ck1)
        (tinj set "path" tpath) drop
        (tinj set "nodes" (vg-slice inodes -1 vg-noarg vg-noarg)) drop
        (tinj set "parent" (vg-getelem (tinj get "nodes") -1 vg-noarg)) drop
        (vg-setprop (tinj get "parent") ckey tval) drop
        (tinj set "val" tval) drop
        (tinj set "dpath" dpath) drop
        (tinj set "dparent" (tcurbox get 0)) drop
        (vg-inject tval store tinj) drop
        (rvalbox set 0 (tinj get "val")) drop
        none
      ] [none] drop
      def rval (rvalbox get 0)
      (vg-setprop target tkey rval) drop
      def ter4 (vg-getprop rval 0 vg-noarg)
      ter4
    ]
  ] [none]
]]

def vg-t-pack fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (vg-checkplacement 1 "EACH" vg-t-map inj) [
    def ikey (inj get "key")
    def ipath (inj get "path")
    def parent (inj get "parent")
    def inodes (inj get "nodes")
    def cargs (vg-getprop parent ikey vg-noarg)
    def want (flex [])
    (append [vg-t-string] want) drop
    (append [vg-t-any] want) drop
    def found (vg-injectorargs want cargs)
    def errv (found get 0)
    if ((errv is None) not) [
      def msg (StringUtil.concat ["$EACH: " errv])
      (append [msg] (inj get "errs")) drop
      none
    ] [
      def srcpath (found get 1)
      def origchildspec (found get 2)
      def tkey (vg-getelem ipath -2 vg-noarg)
      def pathsize (vgz ipath)
      def target0 (vg-getelem inodes (pathsize sub 2) vg-noarg)
      def target (if (target0 is None) [vg-getelem inodes (pathsize sub 1) vg-noarg] [target0])
      def ibase (inj get "base")
      def srcstore (vg-getprop store ibase store)
      def src0 (vg-getpath srcstore srcpath inj)
      def src (
        if (vg-islist src0) [src0] [
          if (vg-ismap src0) [
            def acc (flex [])
            def prs (vg-items src0)
            def tag ([pr:Any] => [
              def nd (pr get 1)
              def kv (flex {})
              (vg-setprop kv "KEY" (pr get 0)) drop
              (vg-setprop nd "`$ANNO`" kv) drop
              nd
            ])
            def r (vgl-items-apply 0 prs [tag/r] acc)
            r
          ] [none]
        ]
      )
      if (src is None) [none] [
        def keypath (vg-getprop origchildspec "`$KEY`" vg-noarg)
        def childspec (vg-delprop origchildspec "`$KEY`")
        def child (vg-getprop childspec "`$VAL`" childspec)
        def tval (flex {})
        def mkentry ([pr:Any] => [
          def srckey (pr get 0)
          def srcnode (pr get 1)
          def nkey (
            if (keypath is None) [srckey] [
              if (vgi-starts-with keypath "`") [
                def ms (flex [])
                (append [(flex {})] ms) drop
                (append [store] ms) drop
                def topm (flex {})
                (vg-setprop topm "$TOP" srcnode) drop
                (append [topm] ms) drop
                def vstore (vg-merge ms 1)
                def r2 (vg-inject keypath vstore vg-noarg)
                r2
              ] [
                def r2 (vg-getpath srcnode keypath vg-noarg)
                r2
              ]
            ]
          )
          def tchild (vg-clone child)
          (vg-setprop tval nkey tchild) drop
          def anno (vg-getprop srcnode "`$ANNO`" vg-noarg)
          if (anno is None) [
            (vg-delprop tchild "`$ANNO`") drop
            none
          ] [
            (vg-setprop tchild "`$ANNO`" anno) drop
            none
          ] drop
          none
        ])
        (vgl-items-apply 0 (vg-items src) [mkentry/r] (flex [])) drop
        def rvalbox (flex [none])
        (rvalbox set 0 (flex {})) drop
        if ((vg-isempty tval) not) [
          def tsrc (flex {})
          def ibox (flex [0])
          def addsrc ([pr:Any] => [
            def n2 (pr get 1)
            def i2 (ibox get 0)
            def kn (
              if (keypath is None) [i2] [
                if (vgi-starts-with keypath "`") [
                  def ms (flex [])
                  (append [(flex {})] ms) drop
                  (append [store] ms) drop
                  def topm (flex {})
                  (vg-setprop topm "$TOP" n2) drop
                  (append [topm] ms) drop
                  def vstore (vg-merge ms 1)
                  def r2 (vg-inject keypath vstore vg-noarg)
                  r2
                ] [
                  def r2 (vg-getpath n2 keypath vg-noarg)
                  r2
                ]
              ]
            )
            (vg-setprop tsrc kn n2) drop
            (ibox set 0 (i2 add 1)) drop
            none
          ])
          (vgl-items-apply 0 (vg-items src) [addsrc/r] (flex [])) drop
          def tpath (vg-slice ipath -1 vg-noarg vg-noarg)
          def ckey (vg-getelem ipath -2 vg-noarg)
          def dpath (flex [])
          (append ["$TOP"] dpath) drop
          def sparts (make FlexList (StringUtil.split "." srcpath {keepEmpty: true}))
          (vgl-shallow 0 sparts dpath) drop
          (append [(StringUtil.concat ["$:" (vg-js-string ckey)])] dpath) drop
          def tcur1 (flex {})
          (vg-setprop tcur1 ckey tsrc) drop
          def tcurbox (flex [none])
          (tcurbox set 0 tcur1) drop
          if ((vgz tpath) gt 1) [
            def pkey (vg-getelem ipath -3 "$TOP")
            def tcur2 (flex {})
            (vg-setprop tcur2 pkey (tcurbox get 0)) drop
            (tcurbox set 0 tcur2) drop
            (append [(StringUtil.concat ["$:" (vg-js-string pkey)])] dpath) drop
            none
          ] [none] drop
          def ck1 (flex [])
          (append [ckey] ck1) drop
          def tinj (vgi-inj-child inj 0 ck1)
          (tinj set "path" tpath) drop
          (tinj set "nodes" (vg-slice inodes -1 vg-noarg vg-noarg)) drop
          (tinj set "parent" (vg-getelem (tinj get "nodes") -1 vg-noarg)) drop
          (tinj set "val" tval) drop
          (tinj set "dpath" dpath) drop
          (tinj set "dparent" (tcurbox get 0)) drop
          (vg-inject tval store tinj) drop
          (rvalbox set 0 (tinj get "val")) drop
          none
        ] [none] drop
        (vg-setprop target tkey (rvalbox get 0)) drop
        none
      ]
    ]
  ] [none]
]]

def vg-t-ref fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (((inj get "mode") eq 4) not) [none] [
    def inodes (inj get "nodes")
    def ipath (inj get "path")
    def refpath (vgi-lookup (inj get "parent") 1)
    (inj set "keyi" (vgz (inj get "keys"))) drop
    def specbox (vg-getprop store "$SPEC" vg-noarg)
    def sf (vgi-fnarg specbox)
    def spec (none sf/r apply)
    def dpath (vg-slice ipath 1 vg-noarg vg-noarg)
    def rinj (flex {})
    (rinj set "dpath" dpath) drop
    (rinj set "dparent" (vg-getpath spec dpath vg-noarg)) drop
    def refv (vg-getpath spec refpath rinj)
    def subrefbox (flex [false])
    if (vg-isnode refv) [
      def cb ([k2:Any v2:Any p2:Any pth2:Any] => [
        if (v2 eq "`$REF`") [(subrefbox set 0 true) drop none] [none] drop
        v2
      ])
      (vg-walk refv [cb/r] vg-noarg vg-noarg) drop
      none
    ] [none] drop
    def hassubref (subrefbox get 0)
    def tref (vg-clone refv)
    def cpath (vg-slice ipath -3 vg-noarg vg-noarg)
    def tpath (vg-slice ipath -1 vg-noarg vg-noarg)
    def tcur (vg-getpath store cpath vg-noarg)
    def tval (vg-getpath store tpath vg-noarg)
    def rvalbox (flex [none])
    if ((hassubref not) or ((tval is None) not)) [
      def lk (flex [])
      (append [(vg-getelem tpath -1 vg-noarg)] lk) drop
      def tinj (vgi-inj-child inj 0 lk)
      (tinj set "path" tpath) drop
      (tinj set "nodes" (vg-slice inodes -1 vg-noarg vg-noarg)) drop
      (tinj set "parent" (vg-getelem inodes -2 vg-noarg)) drop
      (tinj set "val" tref) drop
      def cp2 (flex [])
      (append [cpath] cp2) drop
      (tinj set "dpath" (vg-flatten cp2 1)) drop
      (tinj set "dparent" tcur) drop
      (vg-inject tref store tinj) drop
      (rvalbox set 0 (tinj get "val")) drop
      none
    ] [none] drop
    def grandparent (vgi-inj-setval inj (rvalbox get 0) 2)
    def prior (inj get "prior")
    if ((vg-islist grandparent) and ((prior is None) not)) [
      (prior set "keyi" ((prior get "keyi") sub 1)) drop
      none
    ] [none] drop
    val
  ]
]]

# The $FORMAT formatter callbacks (walk appliers).
def vg-fmt-identity fn [[k:Any v:Any p:Any pth:Any] [Any] [v]]
def vg-fmt-upper fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-isnode v) [v] [StringUtil.upper (vg-js-string v)]
]]
def vg-fmt-lower fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-isnode v) [v] [StringUtil.lower (vg-js-string v)]
]]
def vg-fmt-string fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-isnode v) [v] [vg-js-string v]
]]
def vgi-tonum fn [[v:Any] [Any] [
  if (v is Number) [v] [
    if (v is Boolean) [if v [1] [0]] [
      if (v is None) [0] [
        if (v is String) [
          def n (do [convert Float (StringUtil.trim v)] error [drop none])
          if (n is None) [
            def n2 (vgi-parse-int v)
            if (n2 is None) [0] [n2]
          ] [n]
        ] [0]
      ]
    ]
  ]
]]
def vg-fmt-number fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-isnode v) [v] [
    def n (vgi-tonum v)
    if (n is Float) [
      def fl (MathUtil.floor n)
      if (fl eq n) [fl] [n]
    ] [n]
  ]
]]
def vg-fmt-integer fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-isnode v) [v] [
    def n (vgi-tonum v)
    if (n is Float) [MathUtil.trunc n] [n]
  ]
]]
def vg-fmt-concat fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if ((k is None) and (vg-islist v)) [
    def acc (flex [])
    def prs (vg-items v)
    def pickfmt ([pr:Any] => [
      def e (pr get 1)
      if (vg-isnode e) [""] [vg-js-string e]
    ])
    def strs (vgl-items-apply 0 prs [pickfmt/r] acc)
    def btr27 (vg-join strs "" vg-noarg)
    btr27
  ] [v]
]]
def vg-formatter-table {
  identity: {"`$FN`": vg-fmt-identity/r}
  upper: {"`$FN`": vg-fmt-upper/r}
  lower: {"`$FN`": vg-fmt-lower/r}
  string: {"`$FN`": vg-fmt-string/r}
  number: {"`$FN`": vg-fmt-number/r}
  integer: {"`$FN`": vg-fmt-integer/r}
  concat: {"`$FN`": vg-fmt-concat/r}
}

def vg-t-format fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  (vg-slice (inj get "keys") 0 1 true) drop
  if (((inj get "mode") eq 4) not) [none] [
    def parent (inj get "parent")
    def fname (vgi-lookup parent 1)
    def child (vgi-lookup parent 2)
    def ipath (inj get "path")
    def inodes (inj get "nodes")
    def tkey (vg-getelem ipath -2 vg-noarg)
    def target0 (vg-getelem inodes -2 vg-noarg)
    def target (if (target0 is None) [vg-getelem inodes -1 vg-noarg] [target0])
    def cinj (vg-injectchild child store inj)
    def resolved (cinj get "val")
    def formatter (
      if (vg-isfunc fname) [fname] [vg-getprop vg-formatter-table fname vg-noarg]
    )
    if (formatter is None) [
      def msg (StringUtil.concat ["$FORMAT: unknown format: " (vg-js-string fname) "."])
      (append [msg] (inj get "errs")) drop
      none
    ] [
      def out (vg-walk resolved formatter vg-noarg vg-noarg)
      (vg-setprop target tkey out) drop
      out
    ]
  ]
]]

def vg-t-apply fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if (vg-checkplacement 4 "APPLY" vg-t-list inj) [
    def parent (inj get "parent")
    def cargs (vg-slice parent 1 vg-noarg vg-noarg)
    def want (flex [])
    (append [vg-t-function] want) drop
    (append [vg-t-any] want) drop
    def found (vg-injectorargs want cargs)
    def errv (found get 0)
    if ((errv is None) not) [
      def msg (StringUtil.concat ["$APPLY: " errv])
      (append [msg] (inj get "errs")) drop
      none
    ] [
      def af (found get 1)
      def child (found get 2)
      def ipath (inj get "path")
      def inodes (inj get "nodes")
      def tkey (vg-getelem ipath -2 vg-noarg)
      def target0 (vg-getelem inodes -2 vg-noarg)
      def target (if (target0 is None) [vg-getelem inodes -1 vg-noarg] [target0])
      def cinj (vg-injectchild child store inj)
      def resolved (cinj get "val")
      def f (vgi-fnarg af)
      def out (vgi-call2 resolved store (f/r))
      (vg-setprop target tkey out) drop
      out
    ]
  ] [none]
]]

def vg-t-bt fn [[inj:Any val:Any iref:Any store:Any] [Any] ["`"]]
def vg-t-ds fn [[inj:Any val:Any iref:Any store:Any] [Any] ["$"]]
def vg-t-when fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  # JS Date.toISOString() has exactly millisecond precision; trim the
  # engine's nanosecond rendering to match (2026-01-02T03:04:05.678Z).
  def s (convert String (TimeUtil.now))
  if ((size s) gt 24) [StringUtil.concat [(s slice 0 23) "Z"]] [s]
]]

# The default inject handler: call store command functions; otherwise
# write full-string injection results back into the parent.
def vg-injecthandler fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def iscmd (
    if (vg-isfunc val) [
      if (iref is None) [true] [
        if (iref is String) [vgi-starts-with iref "$"] [false]
      ]
    ] [false]
  )
  if (iscmd eq true) [
    def f (vgi-fnarg val)
    def out (vgi-call4 inj val iref store (f/r))
    out
  ] [
    if (((inj get "mode") eq 4) and ((inj get "full") eq true)) [
      (vgi-inj-setval inj val 1) drop
      val
    ] [val]
  ]
]]
def vg-injecthandler-box {"`$FN`": vg-injecthandler/r}

# ----------------------------------------------------------------------------
# transform — by-example transformation of data via a spec.
# ----------------------------------------------------------------------------
def vg-transform fn [[data:Any spec:Any injdef:Any] [Any] [
  def idf (if (vg-is-noarg injdef) [none] [injdef])
  def origspec spec
  def spec2 (vg-clone spec)
  def extra (vgi-idef idf "extra")
  def ierrs (vgi-idef idf "errs")
  def collect ((ierrs is None) not)
  def errs (if (ierrs is None) [flex []] [ierrs])
  def extratransforms (flex {})
  def extradata (flex {})
  if ((extra is None) not) [
    def prs (vg-items extra)
    def split1 ([pr:Any] => [
      def k (pr get 0)
      def v2 (pr get 1)
      if (vgi-starts-with k "$") [
        (vg-setprop extratransforms k v2) drop
        none
      ] [
        (vg-setprop extradata k v2) drop
        none
      ] drop
      none
    ])
    (vgl-items-apply 0 prs [split1/r] (flex [])) drop
    none
  ] [none] drop
  def ml (flex [])
  def ed (
    if (vg-isempty extradata) [none] [vg-clone extradata]
  )
  (append [ed] ml) drop
  (append [(vg-clone data)] ml) drop
  def dataclone (vg-merge ml vg-noarg)
  def specfn ([ig:Any] => [origspec])
  def basestore (do {
    "$TOP": (dataclone)
    "$SPEC": ({} set "`$FN`" (specfn/r))
    "$BT": (vg-t-bt-box)
    "$DS": (vg-t-ds-box)
    "$WHEN": (vg-t-when-box)
    "$DELETE": (vg-t-delete-box)
    "$COPY": (vg-t-copy-box)
    "$KEY": (vg-t-key-box)
    "$ANNO": (vg-t-anno-box)
    "$MERGE": (vg-t-merge-box)
    "$EACH": (vg-t-each-box)
    "$PACK": (vg-t-pack-box)
    "$REF": (vg-t-ref-box)
    "$FORMAT": (vg-t-format-box)
    "$APPLY": (vg-t-apply-box)
  })
  def sl (flex [])
  (append [basestore] sl) drop
  (append [extratransforms] sl) drop
  def errsm (flex {})
  (vg-setprop errsm "$ERRS" errs) drop
  (append [errsm] sl) drop
  def store (vg-merge sl 1)
  def out (vg-inject spec2 store idf)
  if (((vgz errs) gt 0) and (collect not)) [
    def msg (vg-join errs " | " vg-noarg)
    raise {code: struct_error/q message: (msg)}
  ] [none] drop
  out
]]
def vg-t-delete-box {"`$FN`": vg-t-delete/r}
def vg-t-copy-box {"`$FN`": vg-t-copy/r}
def vg-t-key-box {"`$FN`": vg-t-key/r}
def vg-t-anno-box {"`$FN`": vg-t-anno/r}
def vg-t-merge-box {"`$FN`": vg-t-merge/r}
def vg-t-each-box {"`$FN`": vg-t-each/r}
def vg-t-pack-box {"`$FN`": vg-t-pack/r}
def vg-t-ref-box {"`$FN`": vg-t-ref/r}
def vg-t-format-box {"`$FN`": vg-t-format/r}
def vg-t-apply-box {"`$FN`": vg-t-apply/r}
def vg-t-bt-box {"`$FN`": vg-t-bt/r}
def vg-t-ds-box {"`$FN`": vg-t-ds/r}
def vg-t-when-box {"`$FN`": vg-t-when/r}

# ----------------------------------------------------------------------------
# validate — shape validation via the transform machinery.
# Command handlers mirror the canonical validate_* injectors.
# ----------------------------------------------------------------------------

# TYPENAME.indexOf(tname) → 1 << (31 - idx): identical to the T_* constants.
def vg-vtype-map {any: 2147483647 nil: 1073741824 boolean: 536870912 decimal: 268435456 integer: 134217728 number: 67108864 string: 33554432 function: 16777216 symbol: 8388608 null: 4194304 list: 16384 map: 8192 instance: 4096 scalar: 128 node: 64}

# Build a type validation error message (canonical _invalidTypeMsg).
def vgi-invalid-type-msg fn [[path:Any needtype:String vt:Integer v:Any] [String] [
  def vs (if (v is None) ["no value"] [vg-stringify v vg-noarg vg-noarg])
  def fieldpart (
    if ((vgz path) gt 1) [StringUtil.concat ["field " (vg-pathify path 1 vg-noarg) " to be "]] [""]
  )
  def typepart (
    if ((v is None) not) [StringUtil.concat [(vg-typename vt) ": "]] [""]
  )
  def msg (StringUtil.concat ["Expected " fieldpart needtype ", but found " typepart vs "."])
  msg
]]

# Lowercase `$NAME` transform names inside a description string.
def vg-lower-tname-cb fn [[ml:Any] [Any] [
  def low (StringUtil.lower (ml get 1))
  low
]]
def vg-lower-tname-box {"`$FN`": vg-lower-tname-cb/r}
def vgi-valdesc fn [[tvals:Any] [String] [
  def prs (vg-items tvals)
  def acc (flex [])
  def pickv ([pr:Any] => [vg-stringify (pr get 1) vg-noarg vg-noarg])
  (vgl-items-apply 0 prs [pickv/r] acc) drop
  def joined (vgi-join-list acc ", ")
  def low (vg-re-replace "`\\$([A-Z]+)`" joined vg-lower-tname-box)
  low
]]

# Strict-ish scalar equality: deep-equal plus same type bits (mirrors ===).
def vgi-exact-eq fn [[a:Any b:Any] [Boolean] [
  if (a deq b) [(vg-typify a) eq (vg-typify b)] [false]
]]

def vg-v-string fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def fout (vgi-lookup (inj get "dparent") (inj get "key"))
  def t (vg-typify fout)
  if ((BinUtil.band vg-t-string t) eq 0) [
    (append [(vgi-invalid-type-msg (inj get "path") "string" t fout)] (inj get "errs")) drop
    none
  ] [
    if (fout eq "") [
      (append [(StringUtil.concat ["Empty string at " (vg-pathify (inj get "path") 1 vg-noarg)])] (inj get "errs")) drop
      none
    ] [fout]
  ]
]]

# Literal slot presence (a stored null still counts as present) — lets
# the single-null port recover canonical undefined-vs-null for $NIL/$NULL.
def vgi-haslit fn [[v:Any k:Any] [Boolean] [
  if (vg-ismap v) [v has (vgi-map-key k)] [
    if (vg-islist v) [
      def ki (vgi-to-int k)
      if (ki is None) [false] [(ki gte 0) and (ki lt (size v))]
    ] [false]
  ]
]]

def vg-v-type fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def tname (StringUtil.lower (iref slice 1 (size iref)))
  def typev (vg-getprop vg-vtype-map tname 0)
  def fout (vgi-lookup (inj get "dparent") (inj get "key"))
  # An ABSENT slot is canonical undefined (nil); a PRESENT null slot is
  # canonical null. Literal presence recovers the distinction none folds.
  def t (
    if (fout is None) [
      if (vgi-haslit (inj get "dparent") (inj get "key")) [vg-t-null] [vg-t-noval]
    ] [vg-typify fout]
  )
  if ((BinUtil.band t typev) eq 0) [
    (append [(vgi-invalid-type-msg (inj get "path") tname t fout)] (inj get "errs")) drop
    none
  ] [fout]
]]

def vg-v-any fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def fout (vgi-lookup (inj get "dparent") (inj get "key"))
  fout
]]

def vgl-vchild-keys fn [[i:Integer ckeys:Any parent:Any childtm:Any vkeys:Any] [Any] [
  if (i gte (size ckeys)) [none] [
    def ckey (ckeys get i)
    (vg-setprop parent ckey (vg-clone childtm)) drop
    (append [ckey] vkeys) drop
    def r (vgl-vchild-keys (i add 1) ckeys parent childtm vkeys)
    r
  ]
]]
def vgl-vchild-elems fn [[i:Integer n:Integer parent:Any childtm:Any] [Any] [
  if (i gte n) [none] [
    (vg-setprop parent i (vg-clone childtm)) drop
    def r (vgl-vchild-elems (i add 1) n parent childtm)
    r
  ]
]]

def vg-v-child fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def mode (inj get "mode")
  if (mode eq 1) [
    def parent (inj get "parent")
    def key (inj get "key")
    def vkeys (inj get "keys")
    def path (inj get "path")
    def childtm (vg-getprop parent key vg-noarg)
    def pkey (vg-getelem path -2 vg-noarg)
    def tval0 (vg-getprop (inj get "dparent") pkey vg-noarg)
    if (((tval0 is None) not) and ((vg-ismap tval0) not)) [
      (append [(vgi-invalid-type-msg (vg-slice path -1 vg-noarg vg-noarg) "object" (vg-typify tval0) tval0)] (inj get "errs")) drop
      none
    ] [
      def tval (if (tval0 is None) [flex {}] [tval0])
      def ckeys (vg-keysof tval)
      (vgl-vchild-keys 0 ckeys parent childtm vkeys) drop
      (vgi-inj-setval inj none 1) drop
      none
    ]
  ] [
    if (mode eq 4) [
      def parent (inj get "parent")
      if ((vg-islist parent) not) [
        (append ["Invalid $CHILD as value"] (inj get "errs")) drop
        none
      ] [
        def childtm (vgi-lookup parent 1)
        def dparent (inj get "dparent")
        if (dparent is None) [
          (vg-slice parent 0 0 true) drop
          none
        ] [
          if ((vg-islist dparent) not) [
            def msg (vgi-invalid-type-msg (vg-slice (inj get "path") -1 vg-noarg vg-noarg) "list" (vg-typify dparent) dparent)
            (append [msg] (inj get "errs")) drop
            (inj set "keyi" (vgz parent)) drop
            dparent
          ] [
            (vgl-vchild-elems 0 (vgz dparent) parent childtm) drop
            (vg-slice parent 0 (vgz dparent) true) drop
            (inj set "keyi" 0) drop
            def fout (vg-getprop dparent 0 vg-noarg)
            fout
          ]
        ]
      ]
    ] [none]
  ]
]]

# Try each $ONE alternative; true as soon as one validates clean.
def vgl-vone-alts fn [[i:Integer tvals:Any inj:Any store:Any] [Boolean] [
  if (i gte (size tvals)) [false] [
    def tval (tvals get i)
    def terrs (flex [])
    def ml (flex [])
    (append [(flex {})] ml) drop
    (append [store] ml) drop
    def vstore (vg-merge ml 1)
    (vg-setprop vstore "$TOP" (inj get "dparent")) drop
    def idf (flex {})
    (idf set "extra" vstore) drop
    (idf set "errs" terrs) drop
    (idf set "meta" (inj get "meta")) drop
    def vcurrent (vg-validate (inj get "dparent") tval idf)
    (vgi-inj-setval inj vcurrent -2) drop
    if ((vgz terrs) eq 0) [true] [
      def r (vgl-vone-alts (i add 1) tvals inj store)
      r
    ]
  ]
]]

def vg-v-one fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 4) [
    def parent (inj get "parent")
    def keyi (inj get "keyi")
    if (((vg-islist parent) not) or ((keyi eq 0) not)) [
      (append [(StringUtil.concat ["The $ONE validator at field " (vg-pathify (inj get "path") 1 1) " must be the first element of an array."])] (inj get "errs")) drop
      none
    ] [
      (inj set "keyi" (vgz (inj get "keys"))) drop
      (vgi-inj-setval inj (inj get "dparent") 2) drop
      (inj set "path" (vg-slice (inj get "path") -1 vg-noarg vg-noarg)) drop
      (inj set "key" (vg-getelem (inj get "path") -1 vg-noarg)) drop
      def tvals (vg-slice parent 1 vg-noarg vg-noarg)
      if ((vgz tvals) eq 0) [
        (append [(StringUtil.concat ["The $ONE validator at field " (vg-pathify (inj get "path") 1 1) " must have at least one argument."])] (inj get "errs")) drop
        none
      ] [
        def matched (vgl-vone-alts 0 tvals inj store)
        if (matched eq true) [none] [
          def valdesc (vgi-valdesc tvals)
          def pref (if ((vgz tvals) gt 1) ["one of "] [""])
          def need (StringUtil.concat [pref valdesc])
          (append [(vgi-invalid-type-msg (inj get "path") need (vg-typify (inj get "dparent")) (inj get "dparent"))] (inj get "errs")) drop
          none
        ]
      ]
    ]
  ] [none]
]]

def vgl-vexact-alts fn [[i:Integer tvals:Any dp:Any] [Boolean] [
  if (i gte (size tvals)) [false] [
    def tval (tvals get i)
    def em (
      if (vgi-exact-eq tval dp) [true] [
        if (vg-isnode tval) [
          (vg-stringify tval vg-noarg vg-noarg) eq (vg-stringify dp vg-noarg vg-noarg)
        ] [false]
      ]
    )
    if (em eq true) [true] [
      def r (vgl-vexact-alts (i add 1) tvals dp)
      r
    ]
  ]
]]

def vg-v-exact fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 4) [
    def parent (inj get "parent")
    def keyi (inj get "keyi")
    if (((vg-islist parent) not) or ((keyi eq 0) not)) [
      (append [(StringUtil.concat ["The $EXACT validator at field " (vg-pathify (inj get "path") 1 1) " must be the first element of an array."])] (inj get "errs")) drop
      none
    ] [
      (inj set "keyi" (vgz (inj get "keys"))) drop
      (vgi-inj-setval inj (inj get "dparent") 2) drop
      (inj set "path" (vg-slice (inj get "path") 0 -1 vg-noarg)) drop
      (inj set "key" (vg-getelem (inj get "path") -1 vg-noarg)) drop
      def tvals (vg-slice parent 1 vg-noarg vg-noarg)
      if ((vgz tvals) eq 0) [
        (append [(StringUtil.concat ["The $EXACT validator at field " (vg-pathify (inj get "path") 1 1) " must have at least one argument."])] (inj get "errs")) drop
        none
      ] [
        def matched (vgl-vexact-alts 0 tvals (inj get "dparent"))
        if (matched eq true) [none] [
          def valdesc (vgi-valdesc tvals)
          def p1 (if ((vgz (inj get "path")) gt 1) [""] ["value "])
          def p2 (if ((vgz tvals) eq 1) [""] ["one of "])
          def need (StringUtil.concat [p1 "exactly equal to " p2 valdesc])
          (append [(vgi-invalid-type-msg (inj get "path") need (vg-typify (inj get "dparent")) (inj get "dparent"))] (inj get "errs")) drop
          none
        ]
      ]
    ]
  ] [
    (vg-delprop (inj get "parent") (inj get "key")) drop
    none
  ]
]]

# Literal key presence (stored null still counts as declared).
def vgl-badkeys fn [[i:Integer ckeys:Any pval:Any acc:Any] [Any] [
  if (i gte (size ckeys)) [acc] [
    def ckey (ckeys get i)
    if (pval has (ckey)) [none] [
      (append [ckey] acc) drop
      none
    ] drop
    def r (vgl-badkeys (i add 1) ckeys pval acc)
    r
  ]
]]

# The generic validation modify hook (canonical _validation).
def vg-validation fn [[pval:Any key:Any parent:Any inj:Any store:Any] [Any] [
  if (inj is None) [none] [
    if (vg-is-skip pval) [none] [
      def exact (vg-getprop (inj get "meta") "`$EXACT`" false)
      def cval (vg-getprop (inj get "dparent") key vg-noarg)
      if ((exact eq false) and (cval is None)) [none] [
        def ptype (vg-typify pval)
        if (((BinUtil.band vg-t-string ptype) gt 0) and (StringUtil.contains "$" (vg-js-string pval))) [none] [
          def ctype (vg-typify cval)
          if (((ptype eq ctype) not) and ((pval is None) not)) [
            (append [(vgi-invalid-type-msg (inj get "path") (vg-typename ptype) ctype cval)] (inj get "errs")) drop
            none
          ] [
            if (vg-ismap cval) [
              if ((vg-ismap pval) not) [
                (append [(vgi-invalid-type-msg (inj get "path") (vg-typename ptype) ctype cval)] (inj get "errs")) drop
                none
              ] [
                def ckeys (vg-keysof cval)
                def pkeys (vg-keysof pval)
                if (((vgz pkeys) gt 0) and (((vg-getprop pval "`$OPEN`" vg-noarg) eq true) not)) [
                  def badkeys (vgl-badkeys 0 ckeys pval (flex []))
                  if ((vgz badkeys) gt 0) [
                    (append [(StringUtil.concat ["Unexpected keys at field " (vg-pathify (inj get "path") 1 vg-noarg) ": " (vg-join badkeys ", " vg-noarg)])] (inj get "errs")) drop
                    none
                  ] [none]
                ] [
                  def ml (flex [])
                  (append [pval] ml) drop
                  (append [cval] ml) drop
                  (vg-merge ml vg-noarg) drop
                  if (vg-isnode pval) [(vg-delprop pval "`$OPEN`") drop none] [none] drop
                  none
                ]
              ]
            ] [
              if (vg-islist cval) [
                if ((vg-islist pval) not) [
                  (append [(vgi-invalid-type-msg (inj get "path") (vg-typename ptype) ctype cval)] (inj get "errs")) drop
                  none
                ] [none]
              ] [
                if (exact eq true) [
                  if (vgi-exact-eq cval pval) [none] [
                    def pathmsg (
                      if ((vgz (inj get "path")) gt 1) [StringUtil.concat ["at field " (vg-pathify (inj get "path") 1 vg-noarg) ": "]] [""]
                    )
                    (append [(StringUtil.concat ["Value " pathmsg (vg-js-string cval) " should equal " (vg-js-string pval) "."])] (inj get "errs")) drop
                    none
                  ]
                ] [
                  (vg-setprop parent key cval) drop
                  none
                ]
              ]
            ]
          ]
        ]
      ]
    ]
  ]
]]
def vg-validation-box {"`$FN`": vg-validation/r}

# The validate inject handler: meta paths get special treatment, everything
# else defers to the standard inject handler.
def vg-validatehandler fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  def m (
    if (iref is String) [(iref mini re "^([^$]+)\\$([=~])(.+)$" {})] [do {ok: false}]
  )
  if ((m get "ok") eq true) [
    def g2 (((m get "fst") get "g") get 1)
    if (g2 eq "=") [
      def pairlist (flex [])
      (append ["`$EXACT`"] pairlist) drop
      (append [val] pairlist) drop
      (vgi-inj-setval inj pairlist 1) drop
      none
    ] [
      (vgi-inj-setval inj val 1) drop
      none
    ] drop
    (inj set "keyi" -1) drop
    vg-skip-marker
  ] [
    def fout (vg-injecthandler inj val iref store)
    fout
  ]
]]
def vg-validatehandler-box {"`$FN`": vg-validatehandler/r}

def vg-v-string-box {"`$FN`": vg-v-string/r}
def vg-v-type-box {"`$FN`": vg-v-type/r}
def vg-v-any-box {"`$FN`": vg-v-any/r}
def vg-v-child-box {"`$FN`": vg-v-child/r}
def vg-v-one-box {"`$FN`": vg-v-one/r}
def vg-v-exact-box {"`$FN`": vg-v-exact/r}

def vg-validate fn [[data:Any spec:Any injdef:Any] [Any] [
  def idf (if (vg-is-noarg injdef) [none] [injdef])
  def vextra (vgi-idef idf "extra")
  def ierrs (vgi-idef idf "errs")
  def collect ((ierrs is None) not)
  def errs (if (ierrs is None) [flex []] [ierrs])
  def cmds (do {
    "$DELETE": (none)
    "$COPY": (none)
    "$KEY": (none)
    "$META": (none)
    "$MERGE": (none)
    "$EACH": (none)
    "$PACK": (none)
    "$STRING": (vg-v-string-box)
    "$NUMBER": (vg-v-type-box)
    "$INTEGER": (vg-v-type-box)
    "$DECIMAL": (vg-v-type-box)
    "$BOOLEAN": (vg-v-type-box)
    "$NULL": (vg-v-type-box)
    "$NIL": (vg-v-type-box)
    "$MAP": (vg-v-type-box)
    "$LIST": (vg-v-type-box)
    "$FUNCTION": (vg-v-type-box)
    "$INSTANCE": (vg-v-type-box)
    "$ANY": (vg-v-any-box)
    "$CHILD": (vg-v-child-box)
    "$ONE": (vg-v-one-box)
    "$EXACT": (vg-v-exact-box)
  })
  def sl (flex [])
  (append [cmds] sl) drop
  (append [(if (vextra is None) [flex {}] [vextra])] sl) drop
  def errsm (flex {})
  (vg-setprop errsm "$ERRS" errs) drop
  (append [errsm] sl) drop
  def store (vg-merge sl 1)
  def meta0 (vgi-idef idf "meta")
  def meta (if (meta0 is None) [flex {}] [meta0])
  (vg-setprop meta "`$EXACT`" (vg-getprop meta "`$EXACT`" false)) drop
  def tidf (flex {})
  (tidf set "meta" meta) drop
  (tidf set "extra" store) drop
  (tidf set "modify" vg-validation-box) drop
  (tidf set "handler" vg-validatehandler-box) drop
  (tidf set "errs" errs) drop
  def vout (vg-transform data spec tidf)
  if (((vgz errs) gt 0) and (collect not)) [
    def msg (vg-join errs " | " vg-noarg)
    raise {code: struct_error/q message: (msg)}
  ] [none] drop
  vout
]]

# ----------------------------------------------------------------------------
# select — MongoDB-style child selection built on validate.
# ----------------------------------------------------------------------------
def vgl-sel-terms fn [[i:Integer terms:Any inj:Any store:Any point:Any ppath:Any anyfail:Any] [Any] [
  if (i gte (size terms)) [none] [
    def term (terms get i)
    def terrs (flex [])
    def ml (flex [])
    (append [(flex {})] ml) drop
    (append [store] ml) drop
    def vstore (vg-merge ml 1)
    (vg-setprop vstore "$TOP" point) drop
    def idf (flex {})
    (idf set "extra" vstore) drop
    (idf set "errs" terrs) drop
    (idf set "meta" (inj get "meta")) drop
    (vg-validate point term idf) drop
    if ((vgz terrs) gt 0) [(append [true] anyfail) drop none] [(append [false] anyfail) drop none] drop
    def r (vgl-sel-terms (i add 1) terms inj store point ppath anyfail)
    r
  ]
]]

def vg-s-and fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 1) [
    def terms (vgi-lookup (inj get "parent") (inj get "key"))
    def ppath (vg-slice (inj get "path") -1 vg-noarg vg-noarg)
    def point (vg-getpath store ppath vg-noarg)
    def fails (flex [])
    (vgl-sel-terms 0 terms inj store point ppath fails) drop
    def failed (vg-filter fails [vgi-istrue/r])
    if ((vgz failed) gt 0) [
      (append [(StringUtil.concat ["AND:" (vg-pathify ppath vg-noarg vg-noarg) ": " (vg-stringify point vg-noarg vg-noarg) " fail:" (vg-stringify terms vg-noarg vg-noarg)])] (inj get "errs")) drop
      none
    ] [none] drop
    def gkey (vg-getelem (inj get "path") -2 vg-noarg)
    def gp (vg-getelem (inj get "nodes") -2 vg-noarg)
    (vg-setprop gp gkey point) drop
    none
  ] [none]
]]

def vg-s-or fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 1) [
    def terms (vgi-lookup (inj get "parent") (inj get "key"))
    def ppath (vg-slice (inj get "path") -1 vg-noarg vg-noarg)
    def point (vg-getpath store ppath vg-noarg)
    def fails (flex [])
    (vgl-sel-terms 0 terms inj store point ppath fails) drop
    def passed (vg-filter fails [vgi-isfalse/r])
    if ((vgz passed) gt 0) [
      def gkey (vg-getelem (inj get "path") -2 vg-noarg)
      def gp (vg-getelem (inj get "nodes") -2 vg-noarg)
      (vg-setprop gp gkey point) drop
      none
    ] [
      (append [(StringUtil.concat ["OR:" (vg-pathify ppath vg-noarg vg-noarg) ": " (vg-stringify point vg-noarg vg-noarg) " fail:" (vg-stringify terms vg-noarg vg-noarg)])] (inj get "errs")) drop
      none
    ]
  ] [none]
]]

def vg-s-not fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 1) [
    def term (vgi-lookup (inj get "parent") (inj get "key"))
    def ppath (vg-slice (inj get "path") -1 vg-noarg vg-noarg)
    def point (vg-getpath store ppath vg-noarg)
    def terms1 (flex [])
    (append [term] terms1) drop
    def fails (flex [])
    (vgl-sel-terms 0 terms1 inj store point ppath fails) drop
    if ((fails get 0) eq false) [
      (append [(StringUtil.concat ["NOT:" (vg-pathify ppath vg-noarg vg-noarg) ": " (vg-stringify point vg-noarg vg-noarg) " fail:" (vg-stringify term vg-noarg vg-noarg)])] (inj get "errs")) drop
      none
    ] [none] drop
    def gkey (vg-getelem (inj get "path") -2 vg-noarg)
    def gp (vg-getelem (inj get "nodes") -2 vg-noarg)
    (vg-setprop gp gkey point) drop
    none
  ] [none]
]]

def vg-s-cmp fn [[inj:Any val:Any iref:Any store:Any] [Any] [
  if ((inj get "mode") eq 1) [
    def term (vgi-lookup (inj get "parent") (inj get "key"))
    def gkey (vg-getelem (inj get "path") -2 vg-noarg)
    def ppath (vg-slice (inj get "path") -1 vg-noarg vg-noarg)
    def point (vg-getpath store ppath vg-noarg)
    def pass (
      if (iref eq "$GT") [do [point gt term] error [var [[e] false]]] [
        if (iref eq "$LT") [do [point lt term] error [var [[e] false]]] [
          if (iref eq "$GTE") [do [point gte term] error [var [[e] false]]] [
            if (iref eq "$LTE") [do [point lte term] error [var [[e] false]]] [
              if (iref eq "$LIKE") [vg-re-test term (vg-stringify point vg-noarg vg-noarg)] [false]
            ]
          ]
        ]
      ]
    )
    if (pass eq true) [
      def gp (vg-getelem (inj get "nodes") -2 vg-noarg)
      (vg-setprop gp gkey point) drop
      none
    ] [
      (append [(StringUtil.concat ["CMP: " (vg-pathify ppath vg-noarg vg-noarg) ": " (vg-stringify point vg-noarg vg-noarg) " fail:" iref " " (vg-stringify term vg-noarg vg-noarg)])] (inj get "errs")) drop
      none
    ]
  ] [none]
]]

def vgi-istrue fn [[pr:Any] [Boolean] [(pr get 1) eq true]]
def vgi-isfalse fn [[pr:Any] [Boolean] [(pr get 1) eq false]]

def vg-s-and-box {"`$FN`": vg-s-and/r}
def vg-s-or-box {"`$FN`": vg-s-or/r}
def vg-s-not-box {"`$FN`": vg-s-not/r}
def vg-s-cmp-box {"`$FN`": vg-s-cmp/r}

def vgl-select-kids fn [[i:Integer prs:Any intkeys:Boolean acc:Any] [Any] [
  if (i gte (size prs)) [acc] [
    def pr (prs get i)
    def v (pr get 1)
    def k (if (intkeys eq true) [vgi-to-int (pr get 0)] [pr get 0])
    (vg-setprop v "$KEY" k) drop
    (append [v] acc) drop
    def r (vgl-select-kids (i add 1) prs intkeys acc)
    r
  ]
]]

def vg-open-cb fn [[k:Any v:Any p:Any pth:Any] [Any] [
  if (vg-ismap v) [
    (vg-setprop v "`$OPEN`" (vg-getprop v "`$OPEN`" true)) drop
    none
  ] [none] drop
  v
]]

def vgl-select-match fn [[i:Integer kids:Any q:Any results:Any] [Any] [
  if (i gte (size kids)) [results] [
    def child (kids get i)
    def errs (flex [])
    def meta (flex {})
    (vg-setprop meta "`$EXACT`" true) drop
    def extra (do {
      "$AND": (vg-s-and-box)
      "$OR": (vg-s-or-box)
      "$NOT": (vg-s-not-box)
      "$GT": (vg-s-cmp-box)
      "$LT": (vg-s-cmp-box)
      "$GTE": (vg-s-cmp-box)
      "$LTE": (vg-s-cmp-box)
      "$LIKE": (vg-s-cmp-box)
    })
    def idf (flex {})
    (idf set "errs" errs) drop
    (idf set "meta" meta) drop
    (idf set "extra" extra) drop
    (vg-validate child (vg-clone q) idf) drop
    if ((vgz errs) eq 0) [(append [child] results) drop none] [none] drop
    def r (vgl-select-match (i add 1) kids q results)
    r
  ]
]]

def vg-select fn [[children:Any query:Any] [Any] [
  if ((vg-isnode children) not) [flex []] [
    def prs (vg-items children)
    def kids (vgl-select-kids 0 prs (vg-islist children) (flex []))
    def q (vg-clone query)
    (vg-walk q vg-noarg [vg-open-cb/r] vg-noarg) drop
    def results (vgl-select-match 0 kids q (flex []))
    results
  ]
]]

# ----------------------------------------------------------------------------
# jm / jt — build a JSON map / list from a flat argument list.
# ----------------------------------------------------------------------------
def vgl-jm fn [[i:Integer kv:Any o:Any] [Any] [
  if (i gte (size kv)) [o] [
    def k0 (kv get i)
    def k (if (k0 is String) [k0] [vg-stringify k0 vg-noarg vg-noarg])
    def v (if ((i add 1) lt (size kv)) [kv get (i add 1)] [none])
    (o set (k) v) drop
    def r (vgl-jm (i add 2) kv o)
    r
  ]
]]
def vg-jm fn [[kv:Any] [Any] [
  def o (flex {})
  def r (vgl-jm 0 kv o)
  r
]]
def vgl-jt fn [[i:Integer v:Any a:Any] [Any] [
  if (i gte (size v)) [a] [
    (append [(v get i)] a) drop
    def r (vgl-jt (i add 1) v a)
    r
  ]
]]
def vg-jt fn [[v:Any] [Any] [
  def a (flex [])
  def r (vgl-jt 0 v a)
  r
]]

# ----------------------------------------------------------------------------
# Export (canonical names are the map keys; grows as the port fills out).
# ----------------------------------------------------------------------------
export "Struct" {
  isnode: vg-isnode/r
  ismap: vg-ismap/r
  islist: vg-islist/r
  iskey: vg-iskey/r
  isempty: vg-isempty/r
  isfunc: vg-isfunc/r
  size: vg-size/r
  typify: vg-typify/r
  typename: vg-typename/r
  getdef: vg-getdef/r
  strkey: vg-strkey/r
  keysof: vg-keysof/r
  getprop: vg-getprop/r
  haskey: vg-haskey/r
  getelem: vg-getelem/r
  items: vg-items/r
  filter: vg-filter/r
  flatten: vg-flatten/r
  clone: vg-clone/r
  setprop: vg-setprop/r
  delprop: vg-delprop/r
  stringify: vg-stringify/r
  jsonify: vg-jsonify/r
  pathify: vg-pathify/r
  slice: vg-slice/r
  pad: vg-pad/r
  join: vg-join/r
  escre: vg-escre/r
  escurl: vg-escurl/r
  re_compile: vg-re-compile/r
  re_find: vg-re-find/r
  re_find_all: vg-re-find-all/r
  re_replace: vg-re-replace/r
  re_test: vg-re-test/r
  re_escape: vg-re-escape/r
  walk: vg-walk/r
  merge: vg-merge/r
  getpath: vg-getpath/r
  setpath: vg-setpath/r
  inject: vg-inject/r
  transform: vg-transform/r
  validate: vg-validate/r
  select: vg-select/r
  jm: vg-jm/r
  jt: vg-jt/r
  checkPlacement: vg-checkplacement/r
  injectorArgs: vg-injectorargs/r
  injectChild: vg-injectchild/r
  NOARG: vg-noarg
  SKIP: vg-skip-marker
  DELETE: vg-delete-marker
  T_any: vg-t-any
  T_noval: vg-t-noval
  T_boolean: vg-t-boolean
  T_decimal: vg-t-decimal
  T_integer: vg-t-integer
  T_number: vg-t-number
  T_string: vg-t-string
  T_function: vg-t-function
  T_symbol: vg-t-symbol
  T_null: vg-t-null
  T_list: vg-t-list
  T_map: vg-t-map
  T_instance: vg-t-instance
  T_scalar: vg-t-scalar
  T_node: vg-t-node
  M_KEYPRE: vg-m-keypre
  M_KEYPOST: vg-m-keypost
  M_VAL: vg-m-val
  MODENAME: vg-modename-table
}
