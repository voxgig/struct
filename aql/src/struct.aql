def vg-merge-after fn [[key:Any val:Any parent:Any pth:Any] [Any] [
  def st (vgi-merge-state none)
  def cur (st get "cur")
  def ci (vgz pth)
  def target (vg-getprop cur (ci sub 1) vg-noarg)
  def value (vg-getprop cur ci vg-noarg)
