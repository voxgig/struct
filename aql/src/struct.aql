# ============================================================================
# voxgig/struct — the AQL port.
#
# A faithful port of the canonical TypeScript implementation
# (typescript/src/StructUtility.ts) to the AQL language itself.
# The shared corpus build/test/test.json is the behavioural contract;
# the runner lives in ../test/runner.aql.
#
# Port model (like the Python / Dart / Elixir ports):
#   - single null: AQL `none` plays both JSON null and undefined.
#   - a distinct no-argument sentinel (vg-noarg) marks "argument absent",
#     which is different from "argument is null" (see typify / stringify).
#   - all nodes are flex (FlexMap / FlexList): reference semantics, in-place
#     mutation — the same aliasing model the canonical TS relies on.
#   - regex: the uniform re_* API is built over the engine's RE2 matcher
#     (aql:minilang `mini re`), the same dialect the corpus is limited to.
#
# House rules of this module:
#   - iteration is by tail-recursive MODULE-LEVEL loop functions (vgl-*)
#     with explicit parameters. Named function-valued defs inside fn
#     bodies are avoided: a re-entrant frame's same-named lambda def
#     collides with the outer frame's binding (InstallDef overlap
#     removal), which silently corrupts recursion. Anonymous lambdas
#     passed directly as arguments are safe (params shadow properly).
#   - every internal call is fully parenthesised.
#   - node truthiness is never used bare ({} and "" and 0 are falsy in
#     AQL); predicates are explicit.
#
# Internal words carry a `vg-` prefix (canonical names like `size`, `slice`,
# `filter`, `flatten` are live core AQL words and cannot be rebound); the
# canonical public names are the keys of the `Struct` export map at the end
# of this file.
# ============================================================================

import "aql:string-util"
import "aql:math-util"
import "aql:bin-util"
import "aql:minilang"
import "aql:emitlang"
import "aql:time-util"

# ----------------------------------------------------------------------------
# Mode values for the inject step (bitfield), and type bit codes.
# Values mirror the canonical TS constants exactly.
# ----------------------------------------------------------------------------
def vg-m-keypre 1
def vg-m-keypost 2
def vg-m-val 4

def vg-t-any 2147483647
def vg-t-noval 1073741824
def vg-t-boolean 536870912
def vg-t-decimal 268435456
def vg-t-integer 134217728
def vg-t-number 67108864
def vg-t-string 33554432
def vg-t-function 16777216
def vg-t-symbol 8388608
def vg-t-null 4194304
def vg-t-list 16384
def vg-t-map 8192
def vg-t-instance 4096
def vg-t-scalar 128
def vg-t-node 64

# TYPENAME[clz32(t)] — indexed by the number of leading zero bits.
def vg-typename-table ["any" "nil" "boolean" "decimal" "integer" "number" "string" "function" "symbol" "null" "" "" "" "" "" "" "" "list" "map" "instance" "" "" "" "" "scalar" "node"]

def vg-modename-table {"4": "val" "1": "key:pre" "2": "key:post"}
def vg-placement-table {"4": "value" "1": "key" "2": "key"}

# ----------------------------------------------------------------------------
# Sentinels.
#   vg-noarg         — "no argument given" (like the Dart port's _noarg).
#   vg-skip-marker   — the SKIP marker (compared by identity via eq).
#   vg-delete-marker — the DELETE marker.
# ----------------------------------------------------------------------------
def vg-noarg (quote vg__noarg__)
def vg-skip-marker (flex {"`$SKIP`": true})
def vg-delete-marker (flex {"`$DELETE`": true})

def vg-is-noarg fn [[v:Any] [Boolean] [
  if (v is Atom) [v eq vg-noarg] [false]
]]

def vg-is-skip fn [[v:Any] [Boolean] [
  v eq vg-skip-marker
]]
def vg-is-delete fn [[v:Any] [Boolean] [
  v eq vg-delete-marker
]]

# ----------------------------------------------------------------------------
# Small helpers (JS-semantics shims, as in every port).
# ----------------------------------------------------------------------------

# Bit test: 0 < (mask & t)
def vg-bit fn [[mask:Integer t:Integer] [Boolean] [
  (BinUtil.band mask t) gt 0
]]

# Render a number the way JavaScript does: whole floats print as integers.
def vg-num-to-string fn [[n:Any] [String] [
  if (n is Float) [
    if (MathUtil.is-nan n) ["NaN"] [
      if (MathUtil.is-inf n) [if (n gt 0.0) ["Infinity"] ["-Infinity"]] [
        def fl (MathUtil.floor n)
        if ((fl eq n) and ((MathUtil.abs n) lt 1e16)) [convert String fl] [convert String n]
      ]
    ]
  ] [convert String n]
]]

# Join a list of strings with a separator. NOTE: the core `join` word
# merges separator RUNS (join "/" ["a//" "b"] collapses the slashes), so
# this is a plain interleave-and-concat instead. The public canonical
# join with URL semantics is vg-join below.
def vgl-join-list fn [[i:Integer xs:Any sep:String acc:Any] [Any] [
  if (i gte (size xs)) [acc] [
    if (i gt 0) [(append [sep] acc) drop none] [none] drop
    def e (xs get i)
    (append [e] acc) drop
    def i1 (i add 1)
    def r (vgl-join-list i1 xs sep acc)
    r
  ]
]]
def vgi-join-list fn [[xs:Any sep:String] [String] [
  def acc0 (flex [])
  def parts (vgl-join-list 0 xs sep acc0)
  StringUtil.concat (make List parts)
]]

# JavaScript String(v) coercion.
def vgl-jsstr-list fn [[i:Integer v:Any acc:Any] [Any] [
  if (i gte (size v)) [acc] [
    def e (v get i)
    def es (if (e is None) [""] [vg-js-string e])
    (append [es] acc) drop
    def i1 (i add 1)
    def r (vgl-jsstr-list i1 v acc)
    r
  ]
]]
def vg-js-string fn [[v:Any] [String] [
  if (v is None) ["null"] [
    if (v is Boolean) [if v ["true"] ["false"]] [
      if (v is Number) [vg-num-to-string v] [
        if (v is String) [v] [
          if (v is Function) ["function"] [
            if (v is List) [
              def btr1 (vgi-join-list (vgl-jsstr-list 0 v (flex [])) ",")
              btr1
            ] [
              if (v is Map) ["[object Object]"] [convert String v]
            ]
          ]
        ]
      ]
    ]
  ]
]]

# Map keys are strings: JS coerces every map key through String(k).
def vgi-map-key fn [[k:Any] [String] [
  if (k is String) [k] [
    if (k is Number) [vg-num-to-string k] [vg-js-string k]
  ]
]]

# Strict integer parse of a trimmed string; none when not an integer.
def vgi-parse-int fn [[s:Any] [Any] [
  if (s is String) [
    do [convert Integer (StringUtil.trim s)] error [drop none]
  ] [none]
]]

# JS-ish list-index coercion: int as-is, float floored, numeric string parsed.
def vgi-to-int fn [[k:Any] [Any] [
  if (k is Boolean) [none] [
    if (k is Integer) [k] [
      if (k is Float) [MathUtil.floor k] [
        if (k is String) [vgi-parse-int k] [none]
      ]
    ]
  ]
]]

# JS truthiness (Boolean(v)): none/false/0/NaN/"" are false, all else true.
def vgi-js-truthy fn [[v:Any] [Boolean] [
  if ((v is None) or (vg-is-noarg v)) [false] [
    if (v is Boolean) [v] [
      if (v is Number) [
        if (v is Float) [
          if (MathUtil.is-nan v) [false] [(v eq 0.0) not]
        ] [(v eq 0) not]
      ] [
        if (v is String) [(size v) gt 0] [true]
      ]
    ]
  ]
]]

def vgi-starts-with fn [[s:String prefix:String] [Boolean] [
  def n (size prefix)
  if ((size s) gte n) [(s slice 0 n) eq prefix] [false]
]]

# Call a function value (the check-clean apply idiom). apply binds the
# stack TOP to the function's FIRST parameter, so arguments push in
# reverse. The Function parameter is deliberately LAST: a trailing
# `(f/r)` argument reaches it through the stack, which is the one
# placement a function reference can occupy in a call (references
# never feed forward collection). Zero-argument apply refuses to
# compile, so nullary callables in this port take one ignored argument
# (invoked via vgi-call1 with none).
# NOTE: every helper binds the apply result before returning it. A fn
# body that ENDS in a bare call loses a none result at the return
# boundary (engine quirk); `def r (...) r` keeps the value alive.
def vgi-call1 fn [[a:Any f:Function] [Any] [
  def r (a f/r apply)
  r
]]
def vgi-call2 fn [[a:Any b:Any f:Function] [Any] [
  def r (b a f/r apply)
  r
]]
def vgi-call4 fn [[a:Any b:Any c:Any d:Any f:Function] [Any] [
  def r (d c b a f/r apply)
  r
]]
def vgi-call5 fn [[a:Any b:Any c:Any d:Any e:Any f:Function] [Any] [
  def r (e d c b a f/r apply)
  r
]]

# Function values never travel bare in this port: a bare Function-valued
# name auto-dispatches when stepped, so functions ride inside carriers.
# Two carriers exist:
#   - the FN BOX, a map {"`$FN`": f} — the general "function as data"
#     representation (store commands, handlers, callable alternatives);
#     vg-isfunc recognises it, mirroring the canonical isfunc.
#   - the one-element list [f/r] — used for pure callback slots (walk
#     before/after, filter checks, modify) where canonical code never
#     isfunc-tests the value.
# vgi-fnarg unwraps either carrier to the raw Function (safe to bind
# with def; only bare stepping is unsafe — call via `arg f/r apply`).
def vg-fn-key "`$FN`"
def vgi-fnarg fn [[fw:Any] [Any] [
  if (fw is Map) [
    fw get (vg-fn-key)
  ] [
    if (fw is List) [
      if ((size fw) eq 1) [fw get 0] [fw]
    ] [fw]
  ]
]]

# ----------------------------------------------------------------------------
# Minor utilities (canonical order follows the TS source).
# ----------------------------------------------------------------------------

# Value is a node — a map or list (flex or plain; fn boxes are not nodes).
def vg-isnode fn [[v:Any] [Boolean] [
  if (v is List) [true] [
    if (v is Map) [(vg-isfunc v) not] [false]
  ]
]]

# Value is a map (fn boxes are functions, not maps).
def vg-ismap fn [[v:Any] [Boolean] [
  if (v is Map) [(vg-isfunc v) not] [false]
]]

# Value is a list.
def vg-islist fn [[v:Any] [Boolean] [
  v is List
]]

# Value is a non-empty string or a number.
def vg-iskey fn [[v:Any] [Boolean] [
  if (v is String) [(size v) gt 0] [
    if (v is Boolean) [false] [v is Number]
  ]
]]

# Value is "empty": null/none, empty string, empty list, empty map.
def vg-isempty fn [[v:Any] [Boolean] [
  if ((v is None) or (vg-is-noarg v)) [true] [
    if (v is String) [(size v) eq 0] [
      if (vg-isnode v) [(size v) eq 0] [false]
    ]
  ]
]]

# Value is a function (an FN BOX in this port — see vgi-fnarg).
def vg-isfunc fn [[v:Any] [Boolean] [
  if (v is Map) [
    (typeof (v get (vg-fn-key))) teq Function
  ] [false]
]]

# Natural size of a value (JS Math.floor for numbers — NOT the magnitude).
# vgz is the heavily-used internal spelling; exported as `size`.
def vgz fn [[v:Any] [Integer] [
  if (vg-isnode v) [size v] [
    if (v is String) [size v] [
      if (v is Boolean) [if v [1] [0]] [
        if (v is Integer) [v] [
          if (v is Float) [
            if ((MathUtil.is-nan v) or (MathUtil.is-inf v)) [0] [MathUtil.floor v]
          ] [0]
        ]
      ]
    ]
  ]
]]
def vg-size fn [[v:Any] [Integer] [vgz v]]

# Determine the type of a value as a bit code.
def vg-typify fn [[v:Any] [Integer] [
  if (vg-is-noarg v) [vg-t-noval] [
    if (v is None) [BinUtil.bor vg-t-scalar vg-t-null] [
      if (v is Boolean) [BinUtil.bor vg-t-scalar vg-t-boolean] [
        if (v is Integer) [BinUtil.bor vg-t-scalar (BinUtil.bor vg-t-number vg-t-integer)] [
          if (v is Float) [
            if (MathUtil.is-nan v) [vg-t-noval] [
              if (MathUtil.is-inf v) [BinUtil.bor vg-t-scalar (BinUtil.bor vg-t-number vg-t-decimal)] [
                if ((MathUtil.floor v) eq v) [
                  BinUtil.bor vg-t-scalar (BinUtil.bor vg-t-number vg-t-integer)
                ] [
                  BinUtil.bor vg-t-scalar (BinUtil.bor vg-t-number vg-t-decimal)
                ]
              ]
            ]
          ] [
            if (v is String) [BinUtil.bor vg-t-scalar vg-t-string] [
              if (v is Function) [BinUtil.bor vg-t-scalar vg-t-function] [
                if (v is Atom) [BinUtil.bor vg-t-scalar vg-t-symbol] [
                  if (v is List) [BinUtil.bor vg-t-node vg-t-list] [
                    if (v is Map) [
                      if (vg-isfunc v) [BinUtil.bor vg-t-scalar vg-t-function] [
                        BinUtil.bor vg-t-node vg-t-map
                      ]
                    ] [
                      BinUtil.bor vg-t-node vg-t-instance
                    ]
                  ]
                ]
              ]
            ]
          ]
        ]
      ]
    ]
  ]
]]

# clz32 — leading zeros of a 32-bit value (bit-length complement).
def vgl-bits fn [[x:Integer n:Integer] [Integer] [
  if (x lte 0) [n] [
    def x2 (x div 2)
    def n1 (n add 1)
    def r (vgl-bits x2 n1)
    r
  ]
]]
def vgi-clz32 fn [[t:Integer] [Integer] [
  if (t lte 0) [32] [32 sub (vgl-bits t 0)]
]]

# Type name for the narrowest type bit (fn-body references resolve at
# call time, so the forward use of vg-getelem here is fine).
def vg-typename fn [[t:Any] [String] [
  def ti (if (t is Integer) [t] [if (t is Float) [MathUtil.floor t] [0]])
  def btr2 (vg-getelem vg-typename-table (vgi-clz32 ti) "any")
  btr2
]]

# Get a defined value: alt when val is null/none.
def vg-getdef fn [[v:Any alt:Any] [Any] [
  if ((v is None) or (vg-is-noarg v)) [alt] [v]
]]

# Convert a key to its string form: strings as-is, numbers rendered
# (floats floored), everything else the empty string.
def vg-strkey fn [[k:Any] [String] [
  if ((k is None) or (vg-is-noarg k)) [""] [
    if (k is String) [k] [
      if (k is Boolean) [""] [
        if (k is Integer) [vg-num-to-string k] [
          if (k is Float) [vg-num-to-string (MathUtil.floor k)] [""]
        ]
      ]
    ]
  ]
]]

# Sorted keys of a map, or stringified indexes of a list.
def vgl-idx-keys fn [[i:Integer n:Integer acc:Any] [Any] [
  if (i gte n) [acc] [
    def ky (vg-num-to-string i)
    (append [ky] acc) drop
    def i1 (i add 1)
    def r (vgl-idx-keys i1 n acc)
    r
  ]
]]
def vg-keysof fn [[v:Any] [Any] [
  if (vg-ismap v) [
    def sk (sort (keys v))
    make FlexList sk
  ] [
    if (vg-islist v) [
      def n (size v)
      def acc0 (flex [])
      def r (vgl-idx-keys 0 n acc0)
      r
    ] [flex []]
  ]
]]

# Safely get a property; stored null and absent both fall to alt (Group A).
def vg-getprop fn [[v:Any k:Any alt:Any] [Any] [
  def alt2 (if (vg-is-noarg alt) [none] [alt])
  if ((v is None) or (k is None) or (vg-is-noarg v) or (vg-is-noarg k)) [alt2] [
    def found (
      if (vg-ismap v) [v get (vgi-map-key k)] [
        if (vg-islist v) [
          def ki (vgi-to-int k)
          if (ki is None) [none] [
            if ((ki gte 0) and (ki lt (size v))) [v get ki] [none]
          ]
        ] [none]
      ]
    )
    if (found is None) [alt2] [found]
  ]
]]

# Raw slot lookup for internal Group B callers. With the single-null model
# a stored null IS none, so this is getprop without an alternative.
def vgi-lookup fn [[v:Any k:Any] [Any] [
  def r (vg-getprop v k none)
  r
]]

# Property with name key is defined (stored null counts as no value).
def vg-haskey fn [[v:Any k:Any] [Boolean] [
  ((vg-getprop v k none) is None) not
]]

# ^[-0-9]+$ — integer-looking key (mirrors R_INTEGER_KEY).
def vgi-intkey-ok fn [[s:String] [Boolean] [
  if ((size s) eq 0) [false] [
    (s mini re `^[-0-9]+$` {}).ok
  ]
]]

# Get a list element by integer(ish) key; negative counts from the end.
# A function alt is called lazily when the slot is empty.
def vg-getelem fn [[v:Any k:Any alt:Any] [Any] [
  def alt2 (if (vg-is-noarg alt) [none] [alt])
  if ((v is None) or (k is None) or (vg-is-noarg v) or (vg-is-noarg k)) [alt2] [
    def found (
      if (vg-islist v) [
        def ks (if (k is String) [k] [if (k is Number) [vg-num-to-string k] [""]])
        if (vgi-intkey-ok ks) [
          def n0 (vgi-parse-int ks)
          def n (if (n0 lt 0) [(size v) add n0] [n0])
          if ((n gte 0) and (n lt (size v))) [v get n] [none]
        ] [none]
      ] [none]
    )
    if (found is None) [
      if (vg-isfunc alt2) [
        def f (vgi-fnarg alt2)
        none f/r apply
      ] [alt2]
    ] [found]
  ]
]]

# Raw indexed read: map by string key, list by numeric string.
def vgi-raw fn [[v:Any k:String] [Any] [
  if (vg-ismap v) [v get (k)] [
    if (vg-islist v) [
      def ki (vgi-parse-int k)
      if (ki is None) [none] [
        if ((ki gte 0) and (ki lt (size v))) [v get ki] [none]
      ]
    ] [none]
  ]
]]

# Sorted [key, value] pairs of a map or list.
def vgl-items fn [[i:Integer ks:Any v:Any acc:Any] [Any] [
  if (i gte (size ks)) [acc] [
    def k (ks get i)
    def pair (flex [])
    (append [k] pair) drop
    (append [(vgi-raw v k)] pair) drop
    (append [pair] acc) drop
    def i1 (i add 1)
    def r (vgl-items i1 ks v acc)
    r
  ]
]]
def vg-items fn [[v:Any] [Any] [
  if (vg-isnode v) [
    def ks (vg-keysof v)
    def acc0 (flex [])
    def r (vgl-items 0 ks v acc0)
    r
  ] [flex []]
]]

# items + apply: map each [k,v] pair through a function.
def vgl-items-apply fn [[i:Integer prs:Any fw:Any acc:Any] [Any] [
  if (i gte (size prs)) [acc] [
    def pr (prs get i)
    def f (vgi-fnarg fw)
    def fv (pr f/r apply)
    (append [fv] acc) drop
    def i1 (i add 1)
    def r (vgl-items-apply i1 prs fw acc)
    r
  ]
]]
def vgi-items-apply fn [[v:Any fw:Any] [Any] [
  def prs (vg-items v)
  def acc0 (flex [])
  def r (vgl-items-apply 0 prs fw acc0)
  r
]]

# Filter item values by a check function over [k,v] pairs.
def vgl-filter fn [[i:Integer prs:Any fw:Any acc:Any] [Any] [
  if (i gte (size prs)) [acc] [
    def pair (prs get i)
    def f (vgi-fnarg fw)
    def keepv (pair f/r apply)
    if (keepv eq true) [
      def pv (pair get 1)
      (append [pv] acc) drop
      none
    ] [none] drop
    def i1 (i add 1)
    def r (vgl-filter i1 prs fw acc)
    r
  ]
]]
def vg-filter fn [[v:Any fw:Any] [Any] [
  def prs (vg-items v)
  def acc0 (flex [])
  def r (vgl-filter 0 prs fw acc0)
  r
]]

# Flatten nested lists (one level by default; JS Array.flat semantics).
def vgl-append-all fn [[j:Integer xs2:Any acc:Any] [Any] [
  if (j gte (size xs2)) [acc] [
    def sv (xs2 get j)
    (append [sv] acc) drop
    def j1 (j add 1)
    def r (vgl-append-all j1 xs2 acc)
    r
  ]
]]
def vgl-flatten fn [[i:Integer l:Any d:Integer acc:Any] [Any] [
  if (i gte (size l)) [acc] [
    def it (l get i)
    if ((vg-islist it) and (d gt 0)) [
      (vgl-append-all 0 (vg-flatten it (d sub 1)) acc) drop
      none
    ] [
      (append [it] acc) drop
      none
    ] drop
    def i1 (i add 1)
    def r (vgl-flatten i1 l d acc)
    r
  ]
]]
def vg-flatten fn [[l:Any dep:Any] [Any] [
  def d (if (dep is Number) [vgz dep] [1])
  if (vg-islist l) [
    def acc0 (flex [])
    def r (vgl-flatten 0 l d acc0)
    r
  ] [l]
]]

# Deep clone building flex nodes; functions are copied by reference.
def vgl-clone-map fn [[i:Integer ks:Any v:Any o:Any] [Any] [
  if (i gte (size ks)) [o] [
    def k (ks get i)
    def cv (v get (k))
    def cc (vg-clone cv)
    (o set (k) cc) drop
    def i1 (i add 1)
    def r (vgl-clone-map i1 ks v o)
    r
  ]
]]
def vgl-clone-list fn [[i:Integer v:Any acc:Any] [Any] [
  if (i gte (size v)) [acc] [
    def cv (v get i)
    def cc (vg-clone cv)
    (append [cc] acc) drop
    def i1 (i add 1)
    def r (vgl-clone-list i1 v acc)
    r
  ]
]]
def vg-clone fn [[v:Any] [Any] [
  if (vg-is-noarg v) [none] [
    if (vg-ismap v) [
      def ks (keys v)
      def o0 (flex {})
      def r (vgl-clone-map 0 ks v o0)
      r
    ] [
      if (vg-islist v) [
        def acc0 (flex [])
        def r (vgl-clone-list 0 v acc0)
        r
      ] [v]
    ]
  ]
]]

# Safely set a property in place. Lists: int keys only; above-size appends,
# negative prepends. Returns the (possibly modified) parent.
def vg-setprop fn [[parent:Any k:Any v:Any] [Any] [
  if (vg-iskey k) [
    if (vg-ismap parent) [
      (parent set (vgi-map-key k) v) drop
      none
    ] [
      if (vg-islist parent) [
        def ki (vgi-to-int k)
        if (ki is None) [none] [
          def n (size parent)
          if (ki gte 0) [
            if (ki gte n) [(append [v] parent) drop none] [(parent set ki v) drop none]
          ] [
            (unshift v parent) drop
            none
          ]
        ]
      ] [none]
    ]
  ] [none] drop
  parent
]]

# Safely delete a property in place. Lists shift down.
def vgl-shift-down fn [[i:Integer n:Integer parent:Any] [Any] [
  if (i lt (n sub 1)) [
    def nx (parent get (i add 1))
    (parent set i nx) drop
    def i1 (i add 1)
    def r (vgl-shift-down i1 n parent)
    r
  ] [none]
]]
def vg-delprop fn [[parent:Any k:Any] [Any] [
  if (vg-iskey k) [
    if (vg-ismap parent) [
      (parent del (vg-strkey k)) drop
      none
    ] [
      if (vg-islist parent) [
