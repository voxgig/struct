<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!-- Checkstyle configuration for the Java port.
     A focused, low-noise rule set: it targets real maintainability problems
     (unused imports, empty blocks, equals/hashCode, fall-through, brace
     placement) rather than full Google/Sun formatting enforcement, since the
     port deliberately mirrors the canonical TypeScript source layout. -->
<module name="Checker">
  <property name="charset" value="UTF-8"/>
  <property name="severity" value="warning"/>
  <property name="fileExtensions" value="java"/>

  <module name="LineLength">
    <property name="max" value="120"/>
    <property name="ignorePattern" value="^package.*|^import.*|a href|href|http://|https://"/>
  </module>

  <module name="TreeWalker">
    <!-- Imports -->
    <module name="UnusedImports"/>
    <module name="RedundantImport"/>
    <module name="AvoidStarImport"/>

    <!-- Blocks / braces -->
    <module name="EmptyBlock">
      <property name="option" value="text"/>
    </module>
    <module name="NeedBraces"/>
    <module name="LeftCurly"/>
    <module name="RightCurly"/>

    <!-- Coding problems -->
    <module name="EqualsHashCode"/>
    <module name="FallThrough"/>
    <module name="MissingSwitchDefault"/>
    <module name="SimplifyBooleanExpression"/>
    <module name="SimplifyBooleanReturn"/>
    <module name="StringLiteralEquality"/>
    <module name="EmptyStatement"/>
    <module name="OneStatementPerLine"/>
    <module name="UpperEll"/>
    <module name="ModifierOrder"/>

    <!-- Whitespace -->
    <module name="WhitespaceAfter"/>
    <module name="NoWhitespaceBefore"/>
    <module name="GenericWhitespace"/>
  </module>
</module>
