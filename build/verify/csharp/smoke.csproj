<Project Sdk="Microsoft.NET.Sdk">

  <!-- Smoke client: resolves the LIVE published Voxgig.Struct from nuget.org.
       Version="*" floats to the newest release; the verify target restores with
       a cleared HTTP cache so we exercise the freshest published artifact. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RestoreSources>https://api.nuget.org/v3/index.json</RestoreSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Voxgig.Struct" Version="*" />
  </ItemGroup>

</Project>
