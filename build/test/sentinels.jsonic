
# Conformance category for Group A semantics (UNDEF_SPEC.md).
#
# Each Group A function — getprop, getelem, haskey, isempty, isnode —
# treats a stored JSON null as "no value", indistinguishable from absent.
# Group B functions (setprop, stringify, jsonify, pad, typify) preserve
# null as a real value. These tests exercise the three states side-by-side:
#
#   VALUE  — a regular JSON value
#   NULL   — literal `null` in the JSON
#   ABSENT — key omitted from the map / __UNDEF__ marker elsewhere


# getprop: null and absent both yield alt.
getprop_unify: {
  set: [
    { in: { val:{a:1},    key:'a', alt:'D' }, out: 1   }
    { in: { val:{a:null}, key:'a', alt:'D' }, out: 'D' }
    { in: { val:{},       key:'a', alt:'D' }, out: 'D' }
  ]
}


# getelem on a list slot. null and out-of-range both fall back to alt.
getelem_absent: {
  set: [
    { in: { val:[10,20],   key:0, alt:'D' }, out: 10  }
    { in: { val:[null,20], key:0, alt:'D' }, out: 'D' }
    { in: { val:[],        key:0, alt:'D' }, out: 'D' }
  ]
}


# haskey: null counts as "no value".
haskey_unify: {
  set: [
    { in: { val:{a:1},    key:'a' }, out: true  }
    { in: { val:{a:null}, key:'a' }, out: false }
    { in: { val:{},       key:'a' }, out: false }
  ]
}


# isempty: null, absent, empty string, empty list, empty map all empty;
# any non-empty scalar / container is not empty.
isempty_unify: {
  set: [
    { in: null, out: true  }
    { in: '',   out: true  }
    { in: [],   out: true  }
    { in: {},   out: true  }
    { in: 0,    out: false }
    { in: 'a',  out: false }
    { in: [1],  out: false }
  ]
}


# isnode: null is not a node, neither is absent.
isnode_unify: {
  set: [
    { in: {a:1}, out: true  }
    { in: [1],   out: true  }
    { in: null,  out: false }
    { in: 1,     out: false }
    { in: 'x',   out: false }
  ]
}


# stringify treats null as a value, not as no-value.
stringify_null: {
  set: [
    { in: null, out: 'null' }
    { in: 1,    out: '1'    }
    { in: 'a',  out: 'a'    }
  ]
}
