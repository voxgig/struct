
basic: {
  set: [
    # Basic equality matching
    { id:'select#query', doc:true, in: { query: {age:30}, obj: {a:{name:'Alice',age:30}, b:{name:'Bob',age:25}} },
      out: [{name:'Alice',age:30,'$KEY':'a'}] }

      { in: { query: {name:'Bob'}, obj: {a:{name:'Alice',age:30}, b:{name:'Bob',age:25}} }, 
      out: [{name:'Bob',age:25,'$KEY':'b'}] }
    
    # Multiple field equality
    { in: { query: {age:30,city:'NYC'}, obj: {a:{age:30,city:'NYC'}, b:{age:30,city:'LA'}} }, 
      out: [{age:30,city:'NYC','$KEY':'a'}] }
    
    # Array children
    { in: { query: {type:'user'},
            obj: [{id:1,type:'user'}, {id:2,type:'admin'}, {id:3,type:'user'}] }, 
      out: [{id:1,type:'user','$KEY':0}, {id:3,type:'user','$KEY':2}] }
    
    # No matches
    { in: { query: {age:40}, obj: {a:{age:30}, b:{age:25}} }, 
      out: [] }
    
    # Empty query matches all
    { in: { query: {}, obj: {a:{x:1}, b:{x:2}} },
      out: [{x:1,'$KEY':'a'}, {x:2,'$KEY':'b'}] }

    # Empty query over records with a PRESENT-BUT-NULL field — the null must not
    # drop `b` (design/SELECT_NULL_KEY_BACKPORT.md).
    { in: { query: {}, obj: {a:{opt:'x'}, b:{opt:null}} },
      out: [{opt:'x','$KEY':'a'}, {opt:null,'$KEY':'b'}] }
    
    # Non-object input
    { in: { query: {x:1}, obj: 'hello' }, out: [] }
    { in: { query: {x:1}, obj: 42 }, out: [] }
    { in: { query: {x:1}, obj: null }, out: [] }
    { in: { query: {x:1}, obj: undefined }, out: [] }
    
    # Deep equality for objects
    { in: { query: {data:{x:1,y:2}}, obj: {a:{data:{x:1,y:2}}, b:{data:{x:1,y:3}}} }, 
      out: [{data:{x:1,y:2},'$KEY':'a'}] }
    
    # Deep equality for arrays
    { in: { query: {tags:['a','b']}, obj: {a:{tags:['a','b']}, b:{tags:['a','c']}} }, 
      out: [{tags:['a','b'],'$KEY':'a'}] }
  ]
}

operators: {
  set: [
    # `$AND` operator
    { in: { query: {'`$AND`':[{age:30}, {city:'NYC'}]}, 
            obj: {a:{age:30,city:'NYC'}, b:{age:30,city:'LA'}, c:{age:25,city:'NYC'}} }, 
      out: [{age:30,city:'NYC','$KEY':'a'}] }
    
    # `$AND` with no matches
    { in: { query: {'`$AND`':[{age:30}, {city:'Boston'}]}, 
            obj: {a:{age:30,city:'NYC'}, b:{age:30,city:'LA'}} }, 
      out: [] }
    
    # `$OR` operator
    { in: { query: {'`$OR`':['x', 'y']}, 
            obj: {a:'x', b:'z', c:'y'} }, 
      out: ['x', 'y'] }


    # TODO: review
   
    # { in: { query: {'$KEY':{'`$OR`':['b', 'c']}}, 
    #         obj: {a:'x', b:'z', c:'y'} }, 
    #   out: ['z', 'y'] }

    # { in: { query: {'`$OR`':[{'$KEY':'b'}, {'$KEY':'c'}]}, 
    #         obj: {a:'x', b:'z', c:'y'} }, 
    #   out: ['z', 'y'] }

      
    { in: { query: {'`$OR`':[{age:25}, {age:35}]}, 
            obj: {a:{age:30}, b:{age:25}, c:{age:35}} }, 
      out: [{age:25,'$KEY':'b'}, {age:35,'$KEY':'c'}] }
    
    # `$OR` with all matches
    { in: { query: {'`$OR`':[{type:'user'}, {type:'admin'}]}, 
            obj: [{type:'user'}, {type:'admin'}, {type:'guest'}] }, 
      out: [{type:'user','$KEY':0}, {type:'admin','$KEY':1}] }
    
    # Nested `$AND` within `$OR`
    { in: { query: {'`$OR`':[{'`$AND`':[{role:'user'}, {active:true}]}, {'`$AND`':[{role:'admin'}, {age:30}]}]}, 
            obj: {a:{role:'admin',age:30,active:true}, b:{role:'user',age:25,active:true}, 
                  c:{role:'user',age:30,active:false}, d:{role:'admin',age:30,active:false}} }, 
      out: [{role:'admin',age:30,active:true,'$KEY':'a'}, {role:'user',age:25,active:true,'$KEY':'b'}, 
            {role:'admin',age:30,active:false,'$KEY':'d'}] }
    
    # Complex nested operators
    { in: { query: {'`$AND`':[{'`$OR`':[{status:'active'}, {status:'pending'}]}, {priority:'high'}]}, 
            obj: {a:{status:'active',priority:'high'}, b:{status:'active',priority:'low'}, 
                  c:{status:'pending',priority:'high'}, d:{status:'done',priority:'high'}} }, 
      out: [{status:'active',priority:'high','$KEY':'a'}, {status:'pending',priority:'high','$KEY':'c'}] }
    
    # Empty `$AND` array (should match all)
    { in: { query: {'`$AND`':[]}, obj: {a:{x:1}, b:{x:2}} },
      out: [{x:1,'$KEY':'a'}, {x:2,'$KEY':'b'}] }

    # Empty `$AND` over records with a PRESENT-BUT-NULL field: the null slot must
    # not make the record's own key "unexpected" under the open match, so `b` is
    # kept. Regression for design/SELECT_NULL_KEY_BACKPORT.md — value-based
    # `haskey`/`_lookup == null` ports (go, python, ruby, php, clojure, zig,
    # elixir) drop `b`; canonical uses literal presence (`NONE === _lookup`).
    { in: { query: {'`$AND`':[]}, obj: {a:{opt:'x'}, b:{opt:null}} },
      out: [{opt:'x','$KEY':'a'}, {opt:null,'$KEY':'b'}] }

    # Empty `$OR` array (should match none)
    { in: { query: {'`$OR`':[]}, obj: {a:{x:1}, b:{x:2}} },
      out: [] }

    # $AND of two $OR clauses — both ORs must succeed.
    { in: { query: {'`$AND`':[{'`$OR`':[{role:'admin'},{role:'user'}]},
                              {'`$OR`':[{age:30},{age:35}]}]},
            obj: [{role:'admin',age:30},{role:'admin',age:25},{role:'guest',age:30},
                  {role:'user',age:35},{role:'user',age:40}] },
      out: [{role:'admin',age:30,'$KEY':0},{role:'user',age:35,'$KEY':3}] }

    # $OR over three $AND clauses — any AND triple may match.
    { in: { query: {'`$OR`':[{'`$AND`':[{role:'admin'},{active:true}]},
                             {'`$AND`':[{role:'user'},{age:30}]},
                             {'`$AND`':[{role:'guest'},{vip:true}]}]},
            obj: [{role:'admin',active:true,age:50},{role:'admin',active:false},
                  {role:'user',age:30},{role:'user',age:25},
                  {role:'guest',vip:true},{role:'guest',vip:false}] },
      out: [{role:'admin',active:true,age:50,'$KEY':0},{role:'user',age:30,'$KEY':2},
            {role:'guest',vip:true,'$KEY':4}] }

    # Deep nesting: $OR -> $AND -> $OR.
    { in: { query: {'`$OR`':[{'`$AND`':[{type:'a'},{'`$OR`':[{x:1},{x:2}]}]},
                             {type:'b'}]},
            obj: [{type:'a',x:1},{type:'a',x:2},{type:'a',x:3},{type:'b'},{type:'c'}] },
      out: [{type:'a',x:1,'$KEY':0},{type:'a',x:2,'$KEY':1},{type:'b','$KEY':3}] }

    # $AND with a $NOT term inside.
    { in: { query: {'`$AND`':[{type:'user'},{'`$NOT`':{banned:true}}]},
            obj: [{type:'user',banned:false},{type:'user',banned:true},
                  {type:'admin',banned:false}] },
      out: [{type:'user',banned:false,'$KEY':0}] }

    # $NOT wrapping $AND — excludes records that match both x:1 AND y:2.
    { in: { query: {'`$NOT`':{'`$AND`':[{x:1},{y:2}]}},
            obj: [{x:1,y:2},{x:1,y:3},{x:2,y:2},{x:2,y:3}] },
      out: [{x:1,y:3,'$KEY':1},{x:2,y:2,'$KEY':2},{x:2,y:3,'$KEY':3}] }

    # $NOT wrapping $OR — excludes records matching either branch.
    { in: { query: {'`$NOT`':{'`$OR`':[{x:1},{y:2}]}},
            obj: [{x:1,y:1},{x:2,y:2},{x:2,y:3},{x:3,y:3}] },
      out: [{x:2,y:3,'$KEY':2},{x:3,y:3,'$KEY':3}] }

    # $AND combining $GT and $LT on the same field (range).
    { in: { query: {a:{'`$AND`':[{'`$GT`':10},{'`$LT`':20}]}},
            obj: [{a:5},{a:10},{a:15},{a:20},{a:25}] },
      out: [{a:15,'$KEY':2}] }

    # $OR combining $LT and $GT on the same field (out-of-range).
    { in: { query: {a:{'`$OR`':[{'`$LT`':10},{'`$GT`':20}]}},
            obj: [{a:5},{a:10},{a:15},{a:20},{a:25}] },
      out: [{a:5,'$KEY':0},{a:25,'$KEY':4}] }

    # Empty $OR nested inside $AND — $AND fails (OR matches nothing).
    { in: { query: {'`$AND`':[{x:1},{'`$OR`':[]}]}, obj: [{x:1},{x:2}] },
      out: [] }

    # Empty $AND nested inside $OR — $AND matches everything, $OR succeeds.
    { in: { query: {'`$OR`':[{'`$AND`':[]},{x:1}]}, obj: [{x:1},{x:2}] },
      out: [{x:1,'$KEY':0},{x:2,'$KEY':1}] }

    # Mixed equality plus $AND clause — equality and AND both required.
    { in: { query: {type:'user','`$AND`':[{active:true},{age:30}]},
            obj: [{type:'user',active:true,age:30},{type:'user',active:true,age:25},
                  {type:'admin',active:true,age:30}] },
      out: [{type:'user',active:true,age:30,'$KEY':0}] }

    # Mixed equality, $AND and $OR at the same level.
    { in: { query: {type:'user',
                    '`$AND`':[{active:true}],
                    '`$OR`':[{age:25},{age:30}]},
            obj: [{type:'user',active:true,age:30},{type:'user',active:false,age:30},
                  {type:'user',active:true,age:25},{type:'user',active:true,age:40},
                  {type:'admin',active:true,age:30}] },
      out: [{type:'user',active:true,age:30,'$KEY':0},
            {type:'user',active:true,age:25,'$KEY':2}] }

    # $AND inside $AND (degenerate nesting).
    { in: { query: {'`$AND`':[{'`$AND`':[{x:1},{y:2}]}]},
            obj: [{x:1,y:2},{x:1,y:3},{x:2,y:2}] },
      out: [{x:1,y:2,'$KEY':0}] }

    # $OR inside $OR (degenerate nesting).
    { in: { query: {'`$OR`':[{'`$OR`':[{x:1},{x:2}]},{x:3}]},
            obj: [{x:1},{x:2},{x:3},{x:4}] },
      out: [{x:1,'$KEY':0},{x:2,'$KEY':1},{x:3,'$KEY':2}] }

    # Triple nested $AND($AND($OR)).
    { in: { query: {'`$AND`':[{'`$AND`':[{'`$OR`':[{x:1},{x:2}]}]}]},
            obj: [{x:1},{x:2},{x:3}] },
      out: [{x:1,'$KEY':0},{x:2,'$KEY':1}] }


    { in: { query: {a:{'`$GT`':10}}, obj: [{a:9},{a:10},{a:11},{a:12}] }, 
      out: [{a:11,'$KEY':2},{a:12,'$KEY':3}] }

    { in: { query: {a:{'`$GTE`':10}}, obj: [{a:9},{a:10},{a:11},{a:12}] }, 
      out: [{a:10,'$KEY':1},{a:11,'$KEY':2},{a:12,'$KEY':3}] }

      
    { in: { query: {b:{'`$LT`':10}}, obj: [{b:9},{b:10},{b:11},{b:12}] }, 
      out: [{b:9,'$KEY':0}] }

    { in: { query: {b:{'`$LTE`':10}}, obj: [{b:9},{b:10},{b:11},{b:12}] }, 
      out: [{b:9,'$KEY':0},{b:10,'$KEY':1}] }

      
    { in: { query: {a:b:'`$LT`':10}, obj: [{a:b:9},{a:b:10},{a:b:11},{a:b:12}] }, 
      out: [{a:b:9,'$KEY':0}] }

           
    { in: { query: {x:{y:20}}, obj: [{x:{y:20,z:220}},{x:{y:21,z:221}}] }, 
      out: [{x:{y:20,z:220},'$KEY':0}] }

    { in: { query: {s0:'`$LIKE`':'[aA][bB][cC]'}, obj: [{s0:'DEf'},{s0:'ABc'}] },
      out: [{s0:'ABc','$KEY':1}] }

    # $LIKE — RE2 feature coverage. Every pattern must stay inside the RE2
    # subset documented in /REGEX.md. These tests are the contract: any port
    # whose engine fails one of these has a regex backend gap.

    # Literal substring (re_test reports a match anywhere unless anchored).
    { in: { query: {s:'`$LIKE`':'hello'}, obj: [{s:'say hello world'},{s:'goodbye'}] },
      out: [{s:'say hello world','$KEY':0}] }

    # Anchored at start.
    { in: { query: {s:'`$LIKE`':'^cat'}, obj: [{s:'cat sat'},{s:'a cat'}] },
      out: [{s:'cat sat','$KEY':0}] }

    # Anchored at end.
    { in: { query: {s:'`$LIKE`':'end$'}, obj: [{s:'the end'},{s:'ended here'}] },
      out: [{s:'the end','$KEY':0}] }

    # Both anchors — exact match.
    { in: { query: {s:'`$LIKE`':'^abc$'}, obj: [{s:'abc'},{s:'abcd'},{s:'xabc'}] },
      out: [{s:'abc','$KEY':0}] }

    # `.` matches any single char.
    { in: { query: {s:'`$LIKE`':'^a.c$'}, obj: [{s:'abc'},{s:'aXc'},{s:'ac'}] },
      out: [{s:'abc','$KEY':0},{s:'aXc','$KEY':1}] }

    # `*` zero-or-more (greedy).
    { in: { query: {s:'`$LIKE`':'^ab*c$'}, obj: [{s:'ac'},{s:'abc'},{s:'abbbc'},{s:'abdc'}] },
      out: [{s:'ac','$KEY':0},{s:'abc','$KEY':1},{s:'abbbc','$KEY':2}] }

    # `+` one-or-more.
    { in: { query: {s:'`$LIKE`':'^ab+c$'}, obj: [{s:'ac'},{s:'abc'},{s:'abbbc'}] },
      out: [{s:'abc','$KEY':1},{s:'abbbc','$KEY':2}] }

    # `?` zero-or-one.
    { in: { query: {s:'`$LIKE`':'^colou?r$'}, obj: [{s:'color'},{s:'colour'},{s:'colouur'}] },
      out: [{s:'color','$KEY':0},{s:'colour','$KEY':1}] }

    # Bounded quantifier {n}.
    { in: { query: {s:'`$LIKE`':'^a{3}$'}, obj: [{s:'aa'},{s:'aaa'},{s:'aaaa'}] },
      out: [{s:'aaa','$KEY':1}] }

    # Bounded range {n,m}.
    { in: { query: {s:'`$LIKE`':'^a{2,4}$'}, obj: [{s:'a'},{s:'aa'},{s:'aaa'},{s:'aaaa'},{s:'aaaaa'}] },
      out: [{s:'aa','$KEY':1},{s:'aaa','$KEY':2},{s:'aaaa','$KEY':3}] }

    # Open-ended {n,}.
    { in: { query: {s:'`$LIKE`':'^a{2,}$'}, obj: [{s:'a'},{s:'aa'},{s:'aaa'}] },
      out: [{s:'aa','$KEY':1},{s:'aaa','$KEY':2}] }

    # Character class — positive.
    { in: { query: {s:'`$LIKE`':'^[abc]$'}, obj: [{s:'a'},{s:'b'},{s:'c'},{s:'d'}] },
      out: [{s:'a','$KEY':0},{s:'b','$KEY':1},{s:'c','$KEY':2}] }

    # Character class — negative.
    { in: { query: {s:'`$LIKE`':'^[^xyz]$'}, obj: [{s:'a'},{s:'x'},{s:'y'}] },
      out: [{s:'a','$KEY':0}] }

    # Character range.
    { in: { query: {s:'`$LIKE`':'^[0-9]+$'}, obj: [{s:'123'},{s:'12a'},{s:''}] },
      out: [{s:'123','$KEY':0}] }

    # Predefined class \d.
    { in: { query: {s:'`$LIKE`':'^\\d{3}$'}, obj: [{s:'123'},{s:'12'},{s:'abc'}] },
      out: [{s:'123','$KEY':0}] }

    # Predefined class \w.
    { in: { query: {s:'`$LIKE`':'^\\w+$'}, obj: [{s:'abc_123'},{s:'hi there'}] },
      out: [{s:'abc_123','$KEY':0}] }

    # Predefined class \s.
    { in: { query: {s:'`$LIKE`':'^a\\sb$'}, obj: [{s:'a b'},{s:'a\tb'},{s:'ab'}] },
      out: [{s:'a b','$KEY':0},{s:'a\tb','$KEY':1}] }

    # Negated predefined class \D.
    { in: { query: {s:'`$LIKE`':'^\\D+$'}, obj: [{s:'abc'},{s:'a1'}] },
      out: [{s:'abc','$KEY':0}] }

    # Alternation.
    { in: { query: {s:'`$LIKE`':'^(cat|dog)$'}, obj: [{s:'cat'},{s:'dog'},{s:'fish'}] },
      out: [{s:'cat','$KEY':0},{s:'dog','$KEY':1}] }

    # Non-capturing group with alternation and quantifier.
    { in: { query: {s:'`$LIKE`':'^(?:ab|cd)+$'}, obj: [{s:'ab'},{s:'abcd'},{s:'abcdab'},{s:'abc'}] },
      out: [{s:'ab','$KEY':0},{s:'abcd','$KEY':1},{s:'abcdab','$KEY':2}] }

    # Capturing group used implicitly (engine still matches; we don't expose captures via $LIKE).
    { in: { query: {s:'`$LIKE`':'^a(bc)+d$'}, obj: [{s:'abcd'},{s:'abcbcd'},{s:'ad'}] },
      out: [{s:'abcd','$KEY':0},{s:'abcbcd','$KEY':1}] }

    # Word boundary.
    { in: { query: {s:'`$LIKE`':'\\bword\\b'}, obj: [{s:'a word here'},{s:'sword'},{s:'word!'}] },
      out: [{s:'a word here','$KEY':0},{s:'word!','$KEY':2}] }

    # Escaped metacharacter (literal dot).
    { in: { query: {s:'`$LIKE`':'^a\\.b$'}, obj: [{s:'a.b'},{s:'aXb'}] },
      out: [{s:'a.b','$KEY':0}] }

    # Lazy quantifier (best-effort; engines that don't distinguish should still
    # match the same set since the pattern is anchored).
    { in: { query: {s:'`$LIKE`':'^a.*?b$'}, obj: [{s:'ab'},{s:'aXXXb'},{s:'aXY'}] },
      out: [{s:'ab','$KEY':0},{s:'aXXXb','$KEY':1}] }


    { in: { query: {'`$NOT`':10}, obj: [9,10,11] },
      out: [9,11] }

    { in: { query: {'`$NOT`':{n0:'x'}}, obj: [{n0:x},{n0:y},{n0:z}] }, 
      out: [{n0:y,'$KEY':1},{n0:z,'$KEY':2}] }

    { in: { query: {'`$NOT`':{'`$OR`':[{x:1},{y:2}]}},
            obj: [{x:1,y:3},{x:2,y:2},{x:3,y:1}] }, 
      out: [{x:3,y:1,'$KEY':2}] }
      
  ]
}

edge: {
  set: [
    # Mixed equality and operators
    { in: { query: {type:'user', '`$OR`':[{status:'active'}, {admin:true}]}, 
            obj: [{type:'user',status:'active'}, {type:'user',status:'inactive',admin:true}, 
                  {type:'guest',status:'active'}] }, 
      out: [{type:'user',status:'active','$KEY':0}, {type:'user',status:'inactive',admin:true,'$KEY':1}] }
    
    
    { in: { query: {value:q}, obj: {a:{value:q}, b:{value:p},c:{}} }, 
      out: [{value:q,'$KEY':'a'}] }

    { in: { query: {value:null}, obj: {a:{value:null}, b:{value:0}, c:{}} }, 
      out: [{value:null,'$KEY':'a'}] }
    
    { in: { query: {active:true}, obj: {a:{active:true}, b:{active:false}, c:{active:1}} }, 
      out: [{active:true,'$KEY':'a'}] }
    
    # Number comparison (exact match)
    { in: { query: {count:0}, obj: {a:{count:0}, b:{count:false}, c:{count:'0'}} }, 
      out: [{count:0,'$KEY':'a'}] }

      
    { in: { query: {'`$OR`':[{a:1},{a:2}]}, obj: [{a:0}, {a:1}, {a:2}, {a:3}] }, 
      out: [{a:1,'$KEY':1}, {a:2,'$KEY':2}] }

    { in: { query: {a:{'`$OR`':[10,20]}}, obj: [{a:0}, {a:10}, {a:20}, {a:30}] }, 
      out: [{a:10,'$KEY':1}, {a:20,'$KEY':2}] }

    { in: { query: {a2:{'`$OR`':[{b2:1},{b2:2}]}},
            obj: [{a2:{b2:0}}, {a2:{b2:1}}, {a2:{b2:2}}, {a2:{b2:3}}] }, 
      out: [{a2:{b2:1},'$KEY':1}, {a2:{b2:2},'$KEY':2}] }

    { in: { query: {'`$OR`':[{a3:{'`$OR`':[1]}}]}, obj: [{a3:0}, {a3:1}, {a3:2}] }, 
      out: [{a3:1,'$KEY':1}] }


    { in: { query: {c0:{'`$AND`':[{x:1},{y:2}]}},
            obj: [{c0:{x:1,y:3,z:0}}, {c0:{x:1,y:2,z:1}}] }, 
      out: [{c0:{x:1,y:2,z:1},'$KEY':1}] }

    { in: { query: {c0:{'`$AND`':[{x:1},{y:{'`$OR`':[2,3]}}]}},
            obj: [{c0:{x:1,y:3,z:0}}, {c0:{x:1,y:2,z:1}}, {c0:{x:1,y:1,z:2}}] }, 
      out: [{c0:{x:1,y:3,z:0},'$KEY':0}, {c0:{x:1,y:2,z:1},'$KEY':1}] }     
  ]
}


# path alternates selection
# NOTES FOR SDK:
#  build query by union of all select keys, getting values from operation spec, match
#  need a deterministic sort of alts so multiple selects (should not happen) have at least
#    a stable list of returned alts order. also $path as get out of jail
#      normalize: /a/{x}/b/ -> path$:'/a/{}/b'
#  if no alt found, use select to indicate missing select options
alts: {
  data: obj0: [
    { select:foo_id:true, x:1 }
    { select:bar_id:true, x:2 }
  ]
  data: obj1: [
    { select:{a:A,b:B}, x:11 }
    { select:{a:A,b:B}, x:12 }
  ]
  data: obj2: [
    { select:{query:q0:v0}, x:21 }
    { select:{query:q0:v1}, x:22 }
  ]
  data: obj3: [
    { select:{'$action':foo,zed_id:true}, x:31 }
    { select:{'$action':bar,zed_id:true}, x:32 }
  ]
  
  set: [
    { in: { query: select: {
              foo_id:true  # boolean true means value exists (incl. JSON null)
            }
            obj: $.struct.select.alts.data.obj0 }
      out: [{'$KEY':0,select:foo_id:true,x:1}] }

     { in: { query: select: {  bar_id:true }
             obj: $.struct.select.alts.data.obj0 }
       out: [{'$KEY':1,select:bar_id:true,x:2}]
     }

     # literals always use the string representation
     { in: { query: select: {  a:A,b:B }
             obj: $.struct.select.alts.data.obj1 }
       out: [{ '$KEY': 0, select: { a: 'A', b: 'B' }, x: 11},
             { '$KEY': 1, select: { a: 'A', b: 'B' }, x: 12} ]
     }

     # namespacing query, headers etc. same rules: boolean existence or string literal
     { in: { query: select: {  query:q0:v0 }
             obj: $.struct.select.alts.data.obj2 }
       out: [{ '$KEY': 0, select: { query:q0:v0 }, x: 21} ]
     }
     
     { in: { query: select: { '$action':bar, zed_id:true }
             obj: $.struct.select.alts.data.obj3 }
       out: [{ '$KEY': 1, select: {'$action':bar,zed_id:true}, x: 32} ]
     }

     # empty query matches all
     { in: { query: {}, obj: {a:{x:1},b:{x:2}} },
       out: [{x:1,'$KEY':a},{x:2,'$KEY':b}] }

     # query with no matches
     { in: { query: {z:99}, obj: {a:{x:1},b:{x:2}} },
       out: [] }

  ]
}
